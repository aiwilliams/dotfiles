#!/usr/bin/env bash
# nxs — run an nx-touching command (pnpm test, pnpm dev, nx run ...) inside a
# persistent, memory-capped, per-workspace systemd user scope, so the nx daemon
# it spawns — and any task runners under it — are confined to scope-nx-<ws>-*,
# a sibling of (not a child of) the claude scope that launched them.
#
# Why: in a large Nx monorepo the daemon (nx/dist/src/daemon/server) caches the
# whole project graph and runs builds/tests, and can balloon to tens of GB. It
# detaches and persists, so the peak is never released. Unconfined, two heavy
# bursts exhaust RAM, spill to swap, and systemd-oomd reaps the heaviest-swap
# cgroup at 95% — which keeps landing on clickhouse or the SSH session. Capping
# the *workload* (here) instead of the agent lets claude keep working while a
# runaway daemon is throttled or killed in isolation.
#
# Mechanism: the first nxs command in a workspace births the daemon inside its
# scope; the detached daemon stays in that cgroup, so every later nx client
# (even one not run through nxs) reuses the already-confined daemon over its
# socket. Inspect / reset with `syshealth nx`.
#
# Caps (override via env):
#   NXS_HIGH=16G      MemoryHigh — soft throttle (reclaim/slow) above this
#   NXS_MAX=24G       MemoryMax  — kernel kills the daemon above this; nx
#                                  auto-respawns it on the next command
#   NXS_SWAP_MAX=2G   MemorySwapMax — keeps nx from dominating swap / tripping oomd
#
# On macOS or any host without systemd-run, scope is a transparent pass-through,
# so nxs simply runs the command unchanged.

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: nxs [--] CMD [ARG...]

Run CMD inside the per-workspace nx scope (scope-nx-<workspace>-PID.scope),
capped so a ballooning nx daemon can't take down the rest of the box.

Examples:
  nxs pnpm dev
  nxs pnpm test
  nxs pnpm nx run platform:build

Caps come from NXS_HIGH / NXS_MAX / NXS_SWAP_MAX (defaults 16G / 24G / 2G).
Inspect and reset nx scopes with:  syshealth nx
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  --)        shift ;;
  "")        usage >&2; exit 2 ;;
esac

[ $# -gt 0 ] || { usage >&2; exit 2; }

# Workspace root = nearest ancestor holding an nx.json. Naming the scope after
# the worktree dir keeps each worktree's daemon in its own targetable scope.
root=$PWD
while [ "$root" != / ] && [ ! -e "$root/nx.json" ]; do
  root=$(dirname "$root")
done
if [ ! -e "$root/nx.json" ]; then
  printf 'nxs: no nx.json found at or above %s — not an nx workspace\n' "$PWD" >&2
  exit 2
fi
ws=$(basename "$root")

high=${NXS_HIGH:-16G}
max=${NXS_MAX:-24G}
swap=${NXS_SWAP_MAX:-2G}

# Reuse the scope wrapper for the systemd-run mechanics (single source of truth
# for scope creation, cap properties, oomd preference, and macOS pass-through).
# Resolve it next to this script so the symlinked ~/.local/bin/nxs still finds it.
self=$(readlink -f "$0" 2>/dev/null || echo "$0")
scope="$(dirname "$self")/scope"
[ -x "$scope" ] || scope="scope"

exec "$scope" --name="nx-${ws}" \
  --high="$high" --max="$max" --swap-max="$swap" --oom-avoid \
  -- "$@"
