#!/usr/bin/env bash
# wt — Git worktree manager with per-worktree database isolation.
#
# Uses auto-incrementing wtN identifiers as stable keys for directories,
# databases, and ports. Branches are optional metadata.
#
# Usage:
#   wt create <branch>                  Create worktree with auto-numbered ID on a branch
#   wt create --detach                  Create worktree in detached HEAD state
#   wt checkout [branch]                 Fetch a remote branch and create a worktree (fzf picker if no arg)
#   wt remove [N|wtN]                   Remove worktree + drop DBs (fzf picker if no arg)
#   wt remove --merged                  Remove all worktrees with merged PRs
#   wt list                             List all worktrees with status
#   wt main                             Switch to the main worktree
#   wt merged                           Show worktrees whose branch PR has been merged
#   wt switch [N|wtN|main]               Switch to worktree (fzf picker if no arg)
#   wt env-sync                         Copy main .env to all worktrees
#   wt agent-env                        Write .env.agent for current worktree
#   wt proxy [options] [N|off]           Route HTTPS proxy to a worktree
#   wt ngrok [N|wtN|off]                Tunnel a worktree's port via ngrok
#   wt ps [--all]                       Show running processes for current worktree
#   wt kill [N|wtN|main]                Kill Next.js and Inngest for a worktree
#   wt status                           Show project config, services, and database state
#   wt db-backup [label]                Backup current worktree's databases
#   wt db-restore [timestamp]           Restore databases from a backup

set -euo pipefail

# Prefer GNU column (from util-linux) over macOS BSD column, which chokes on
# multi-byte UTF-8 characters with "column: line too long".
if [[ -x /opt/homebrew/opt/util-linux/bin/column ]]; then
  COLUMN=/opt/homebrew/opt/util-linux/bin/column
else
  COLUMN=column
fi

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="$(cd "$SCRIPT_DIR/../lib" && pwd)"

# shellcheck source=../lib/wt-plugins.sh
source "$LIB_DIR/wt-plugins.sh"
# shellcheck source=../lib/projects.sh
source "$LIB_DIR/projects.sh"
# shellcheck source=../lib/caddy.sh
source "$LIB_DIR/caddy.sh"
# shellcheck source=../lib/ngrok.sh
source "$LIB_DIR/ngrok.sh"

# --------------------------------------------------------------------------
# Helpers
# --------------------------------------------------------------------------

# Get the main worktree directory for the current repo
main_worktree_dir() {
  git worktree list --porcelain | grep '^worktree ' | head -1 | sed 's/^worktree //'
}

# Get the repo base name (directory name of the main worktree)
repo_name() {
  basename "$(main_worktree_dir)"
}

# Get the .env file path within a worktree
env_file_for() {
  echo "$1/apps/platform/.env"
}

# Scan sibling directories matching <repo>-wt[0-9]* and return the lowest
# unused positive integer. Fills gaps: if wt1 and wt3 exist, returns 2.
next_worktree_number() {
  local main_dir
  main_dir=$(main_worktree_dir)
  local parent_dir
  parent_dir=$(dirname "$main_dir")
  local repo
  repo=$(repo_name)

  # Collect all in-use numbers
  local -a used=()
  for dir in "$parent_dir/${repo}"-wt[0-9]*; do
    [[ -d "$dir" ]] || continue
    local name
    name=$(basename "$dir")
    local num="${name#"${repo}-wt"}"
    if [[ "$num" =~ ^[0-9]+$ ]]; then
      used+=("$num")
    fi
  done

  # Find the lowest unused positive integer
  local n=1
  while true; do
    local found=false
    for u in "${used[@]+"${used[@]}"}"; do
      if [[ "$u" -eq "$n" ]]; then
        found=true
        break
      fi
    done
    if [[ "$found" == false ]]; then
      echo "$n"
      return
    fi
    ((n++))
  done
}

# Compute the worktree directory path for a given number
worktree_dir_for_number() {
  local n="$1"
  local main_dir
  main_dir=$(main_worktree_dir)
  echo "$(dirname "$main_dir")/$(repo_name)-wt${n}"
}

# Determine the worktree identifier (e.g. "wt1" or "main") for the current directory.
current_worktree_id() {
  local toplevel
  toplevel=$(git rev-parse --show-toplevel)
  local main_dir
  main_dir=$(main_worktree_dir)

  if [[ "$toplevel" == "$main_dir" ]]; then
    echo "main"
    return
  fi

  local repo dir_name
  repo=$(repo_name)
  dir_name=$(basename "$toplevel")
  if [[ "$dir_name" =~ ^${repo}-wt([0-9]+)$ ]]; then
    echo "wt${BASH_REMATCH[1]}"
    return
  fi

  echo -e "${RED}Cannot determine worktree ID for $toplevel${NC}" >&2
  return 1
}

# Read PROXY_DOMAIN from a worktree's .env file. Returns empty if not set.
read_proxy_domain() {
  local env_file="$1"
  if [[ -f "$env_file" ]]; then
    grep -E '^PROXY_DOMAIN=' "$env_file" | tail -1 | cut -d= -f2 | tr -d '"'"'" || true
  fi
}

# Remove PROXY_DOMAIN from a .env file and reset NEXT_PUBLIC_SITE_URL.
clear_proxy_domain() {
  local env_file="$1"
  local port="$2"
  local host
  host=$(hostname)

  if [[ -f "$env_file" ]]; then
    local tmp
    tmp=$(mktemp)
    grep -v '^PROXY_DOMAIN=' "$env_file" > "$tmp" || true
    # Reset NEXT_PUBLIC_SITE_URL and NEXT_PUBLIC_HOST to hostname:port
    sedi "s|^NEXT_PUBLIC_SITE_URL=.*|NEXT_PUBLIC_SITE_URL=https://${host}:${port}|" "$tmp"
    sedi "s|^NEXT_PUBLIC_HOST=.*|NEXT_PUBLIC_HOST=${host}|" "$tmp"
    mv "$tmp" "$env_file"
  fi
}

# Set PROXY_DOMAIN in a .env file and update NEXT_PUBLIC_SITE_URL.
set_proxy_domain() {
  local env_file="$1"
  local domain="$2"
  local proxy_port=5443

  if [[ -f "$env_file" ]]; then
    # Remove existing PROXY_DOMAIN line if present
    local tmp
    tmp=$(mktemp)
    grep -v '^PROXY_DOMAIN=' "$env_file" > "$tmp" || true
    # Add it back
    printf '%s\n' "$(<"$tmp")" > "$tmp"
    echo "" >> "$tmp"
    echo "PROXY_DOMAIN=${domain}" >> "$tmp"
    mv "$tmp" "$env_file"
    # Update NEXT_PUBLIC_SITE_URL and NEXT_PUBLIC_HOST
    sedi "s|^NEXT_PUBLIC_SITE_URL=.*|NEXT_PUBLIC_SITE_URL=https://${domain}:${proxy_port}|" "$env_file"
    sedi "s|^NEXT_PUBLIC_HOST=.*|NEXT_PUBLIC_HOST=${domain}|" "$env_file"
  fi
}

# Compute port from worktree number: 3000 + N
compute_port() {
  local n="$1"
  local port=$((3000 + n))
  if [[ "$port" -gt 65535 ]]; then
    echo -e "${RED}Port ${port} exceeds 65535${NC}" >&2
    exit 1
  fi
  echo "$port"
}

# Write .env.agent with agent-visible env vars from all plugins.
# Also writes .mise.local.toml so mise loads .env.agent automatically.
write_agent_env() {
  local wt_dir="$1"
  local wt_id="$2"
  local agent_env_file="${wt_dir}/.env.agent"
  : > "$agent_env_file"
  wt_dispatch_hook agent_env "$agent_env_file" "$wt_id"
  echo -e "${GREEN}Wrote agent env${NC} ${DIM}(${agent_env_file})${NC}"

  local mise_local="${wt_dir}/.mise.local.toml"
  if [[ ! -f "$mise_local" ]] || ! grep -qF '.env.agent' "$mise_local"; then
    printf '[env]\n_.file = ".env.agent"\n' > "$mise_local"
  fi
  if command -v mise &>/dev/null; then
    mise trust --quiet "$mise_local" 2>/dev/null || true
  fi
}

# Update PORT, NEXT_PUBLIC_HOST, NEXT_PUBLIC_SITE_URL, and plugin-managed vars in a .env file.
#
# If PROXY_DOMAIN is set in the env file (e.g. opine.localhost), NEXT_PUBLIC_SITE_URL
# and NEXT_PUBLIC_HOST use the proxy domain instead of hostname:port. PORT is still
# set per-worktree (needed for Inngest port mapping and the dev server).
write_env_vars() {
  local env_file="$1"
  local wt_identifier="$2"
  local port="$3"
  local host
  host=$(hostname)

  # Detect PROXY_DOMAIN from the env file (before we strip managed vars)
  local proxy_domain=""
  if [[ -f "$env_file" ]]; then
    proxy_domain=$(grep -E '^PROXY_DOMAIN=' "$env_file" | tail -1 | cut -d= -f2 | tr -d '"'"'" || true)
  fi

  local proxy_port=5443
  local site_url public_host
  if [[ -n "$proxy_domain" ]]; then
    site_url="https://${proxy_domain}:${proxy_port}"
    public_host="$proxy_domain"
  else
    site_url="https://${host}:${port}"
    public_host="$host"
  fi

  # Strip managed vars if the file exists (plugins handle their own vars)
  if [[ -f "$env_file" ]]; then
    local tmp
    tmp=$(mktemp)
    grep -v '^PORT=\|^NEXT_PUBLIC_HOST=\|^NEXT_PUBLIC_SITE_URL=' "$env_file" > "$tmp" || true
    printf '%s\n' "$(<"$tmp")" > "$tmp"
    echo "" >> "$tmp"
    echo "PORT=${port}" >> "$tmp"
    echo "NEXT_PUBLIC_HOST=${public_host}" >> "$tmp"
    echo "NEXT_PUBLIC_SITE_URL=${site_url}" >> "$tmp"
    mv "$tmp" "$env_file"
  else
    mkdir -p "$(dirname "$env_file")"
    {
      echo "PORT=${port}"
      echo "NEXT_PUBLIC_HOST=${public_host}"
      echo "NEXT_PUBLIC_SITE_URL=${site_url}"
    } > "$env_file"
  fi

  wt_dispatch_hook env "$env_file" "$wt_identifier"
}

# --------------------------------------------------------------------------
# Portable sed -i (BSD sed on macOS requires -i '', GNU sed uses -i)
# --------------------------------------------------------------------------

sedi() {
  if sed --version &>/dev/null; then
    sed -i "$@"
  else
    sed -i '' "$@"
  fi
}

# --------------------------------------------------------------------------
# Colors
# --------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --------------------------------------------------------------------------
# Helpers — plugin checks
# --------------------------------------------------------------------------

# Print a warning that no database plugins are configured, with guidance.
# Returns 1 so callers can use: warn_no_plugins && return
warn_no_plugins() {
  [[ ${#WT_PLUGINS[@]} -gt 0 ]] && return 1
  local main_dir
  main_dir=$(main_worktree_dir)
  local wtrc="${main_dir}/.wtrc"
  echo -e "${YELLOW}No database plugins configured.${NC}"
  echo ""
  echo "  wt uses plugins to manage per-worktree databases. Plugins are"
  echo "  declared in a .wtrc file in the main worktree root:"
  echo ""
  echo -e "    ${DIM}${wtrc}${NC}"
  echo ""
  echo "  Example .wtrc:"
  echo ""
  echo "    WT_PLUGINS=(postgres clickhouse)"
  echo "    WT_POSTGRES_DB_PREFIXES=(myapp)"
  echo "    WT_CLICKHOUSE_DB_PREFIXES=(analytics)"
  echo ""
  echo "  Available plugins: postgres, clickhouse."
  echo "  Run 'wt help' for full documentation."
  return 0
}

# --------------------------------------------------------------------------
# Commands
# --------------------------------------------------------------------------

usage() {
  cat <<EOF
Usage: wt <command> [args]

Commands:
  create <branch>                Create worktree on a branch (or --detach for detached HEAD)
  checkout [branch]              Fetch a remote branch and create a worktree (fzf picker if no arg)
  remove [N|wtN]                 Remove worktree and drop DBs (interactive picker if no arg)
  remove --merged                Remove all worktrees with merged PRs
  list                           List all worktrees with ID, branch, port, and status
  main                           Switch to the main worktree
  switch [N|wtN|main]            Switch to worktree (interactive fzf picker if no arg)
  env-sync                       Copy main .env to all worktrees, preserving wt-specific vars
  agent-env                      Write .env.agent for current worktree
  proxy [options] [N|wtN|off]    Route HTTPS proxy to a worktree (show current if no arg)
  ngrok [options] [N|wtN|off]    Tunnel a worktree's port via ngrok (show status if no arg)
  merged                         Show worktrees whose branch PR has been merged
  status                         Show project config, services, and database state
  db-init [--all]                Create databases and update env vars for existing worktrees
  db-status                      Show database status for current worktree
  db-backup [label]              Backup current worktree's databases (optional label)
  db-restore [timestamp]         Restore databases from a backup (fzf picker if no arg)
  kill [N|wtN|main]              Kill Next.js and Inngest processes for a worktree
  help                           Show detailed documentation
EOF
  exit 1
}

cmd_help() {
  cat <<'EOF'
wt — Git worktree manager with per-worktree database isolation.

OVERVIEW

  wt automates creating, managing, and removing git worktrees with isolated
  databases (via plugins) and unique dev-server ports. Each worktree gets an
  auto-incrementing identifier (wt1, wt2, ...) that serves as the stable key
  for its directory, databases, and port. Gaps are filled: if wt1 and wt3
  exist, the next worktree gets wt2.

THE wtN NUMBERING SYSTEM

  Everything derives from the worktree number N:

    Directory   ../<repo>-wt<N>     e.g. ../myapp-wt1
    Databases   <prefix>_wt<N>       e.g. platform_wt1, analytics_wt1
    Port        3000 + N            e.g. 3001 for wt1, 3002 for wt2
    .env        PORT, NEXT_PUBLIC_HOST, NEXT_PUBLIC_SITE_URL, and plugin vars set automatically

COMMANDS

  wt create <branch>
  wt create --detach

    Create a new worktree with the next available wtN identifier. A branch
    name is required — the worktree checks out or creates that branch, copies
    .env from main, clones databases, and runs WT_POST_CREATE if set in .wtrc.
    Use --detach for a detached HEAD worktree.

    Examples:
      wt create my-feature   # worktree on branch my-feature
      wt create --detach     # detached worktree at next wtN

  wt checkout [branch]

    Fetch a remote branch and create a worktree for it. With no argument,
    opens an interactive picker (requires gh + fzf) listing your remote
    branches with PRs that aren't already checked out as worktrees.
    Fetches via Graphite (gt get) if available, otherwise via GitHub CLI
    (gh pr checkout).

    Examples:
      wt checkout                       # interactive picker
      wt checkout use-opine-localhost   # fetch and create worktree directly

  wt remove [N|wtN]

    Remove a worktree and drop its databases. Accepts a number (3) or
    identifier (wt3). With no argument, opens an fzf picker.

    Use --merged to find and remove all worktrees whose PR has been merged
    on GitHub (works with squash merges). Worktrees with uncommitted changes
    are skipped. Prompts for confirmation before removing.

    Examples:
      wt remove 2        # remove wt2
      wt remove wt2      # same thing
      wt remove           # interactive picker
      wt remove --merged  # remove all worktrees with merged PRs

  wt list

    Show all worktrees with their ID, directory, branch, port, dirty status,
    and commit hash.

  wt main

    Switch to the main worktree directory.

  wt switch [N|wtN|main]

    Print a worktree path. With no argument, opens an interactive fzf picker.
    With a number, prints the path directly. Useful with cd: cd $(wt switch 2)

  wt merged

    Show worktrees whose branch has a merged PR on GitHub. Useful for
    finding worktrees that can be cleaned up with wt remove. Uses the
    gh CLI to check PR status, which works correctly with squash merges.

  wt env-sync

    Copy the main worktree's apps/platform/.env to every wtN worktree, then
    re-apply each worktree's specific vars (PORT, NEXT_PUBLIC_HOST,
    NEXT_PUBLIC_SITE_URL, and plugin-managed database vars). PROXY_DOMAIN
    is preserved per-worktree (not copied
    from main). Run this after editing the primary .env to propagate changes
    to all worktrees.

  wt agent-env

    Configure (or reconfigure) the Claude MCP dbhub server for the current
    worktree's database. Idempotent — safe to run multiple times. Must be
    run from inside a numbered worktree directory.

  wt proxy [--host <host>] [--domain <domain>] [N|wtN|off]

    Route the HTTPS proxy to a worktree's port via Caddy.

    Local mode (default): moves PROXY_DOMAIN between worktree .env files
    so only one worktree at a time has it. Domain is read from .env.

    Remote mode (--host): Caddy-only, no .env management. Use this from
    a Mac to route to a dev VM. Reads domain from .env if available, or
    use --domain to specify it explicitly.

    Examples:
      wt proxy 6                          # local: route to wt6
      wt proxy main                       # local: route to main
      wt proxy off                        # stop proxy
      wt proxy                            # show current routing
      wt proxy --host fw 6                # remote: route to fw:3006
      wt proxy --host fw --domain d.test 6  # remote: explicit domain

  wt ngrok [--host <host>] [N|wtN|off]

    Tunnel a worktree's port via ngrok for external webhook access.

    Local mode (default): tunnels to localhost:<port>.

    Remote mode (--host): tunnels to <host>:<port>. Use this from a Mac
    to route webhooks to a dev VM, centralizing all inbound routing.

    Requires NGROK_DOMAIN in your environment (e.g. via ~/.zshenv.local):
      export NGROK_DOMAIN="your-domain.ngrok-free.app"

    Examples:
      wt ngrok 1                      # local: tunnel to wt1 (port 3001)
      wt ngrok main                   # local: tunnel to main (port 3000)
      wt ngrok off                    # stop ngrok
      wt ngrok                        # show current tunnel status
      wt ngrok log                    # tail the ngrok log
      wt ngrok --host fw 6            # remote: tunnel to fw:3006

  wt ps [--all|-a]

    Show running processes for the current worktree: next-server, inngest,
    and database status from active plugins. Use --all to show all worktrees.

    Examples:
      wt ps              # current worktree
      wt ps --all        # all worktrees

  wt kill [N|wtN|main]

    Kill the Next.js and Inngest dev processes for a worktree. Sends SIGTERM
    to the process group and waits for a clean exit before force-killing.

    Examples:
      wt kill 3              # kill processes for wt3
      wt kill wt3            # same thing
      wt kill main           # kill processes for the main worktree

  wt status

    Show an overview of the current project's wt configuration: worktree
    identity, .wtrc plugin configuration, whether required services
    (PostgreSQL, ClickHouse) are running, .env presence, and database
    details from active plugins. This is the best starting point when
    something isn't working or after setting up a new machine.

  wt help

    Show this documentation.

PLUGINS

  wt uses a plugin system for database isolation. Each project declares its
  plugins in a .wtrc file in the main worktree root (shell-sourceable):

    WT_PLUGINS=(postgres clickhouse)
    WT_POSTGRES_DB_PREFIXES=(platform vector)
    WT_CLICKHOUSE_DB_PREFIXES=(analytics)

  Without a .wtrc, no plugins are loaded and no databases are managed.
  Available plugins: postgres, clickhouse.

POST-CREATE HOOK

  Set WT_POST_CREATE in .wtrc to run a command after databases are cloned
  and .env is written. The command runs in the worktree directory with the
  worktree's .env already in place. Fires on both 'wt create' and 'wt db-init'.

  This is useful for project-specific setup that must follow database cloning,
  such as applying schema migrations that haven't reached the main branch yet.

  Example:

    WT_POST_CREATE="tsx ./tools/clickhouse/cli.ts detect-drift --auto-apply-schema-migrations"

COMPANION TOOL: db-worktree

  db-worktree manages PostgreSQL databases independently of git worktrees.
  It can be used directly for lower-level PostgreSQL operations.

  db-worktree subcommands:
    create <id>           Create empty DBs + user
    clone <id> [source]   Clone DBs from source (default: main)
    drop <id>             Drop DBs + user
    list                  List all worktree databases
    env <id>              Print .env connection vars
    status <id>           Show DB sizes, user, extensions
    init-main             Create main branch DBs (first-time setup)

DATABASE MANAGEMENT

  wt db-init [--all]

    Create databases and update database env vars for existing worktrees.
    Useful after adding a new plugin to .wtrc — it creates any missing
    databases and writes the plugin's env vars into .env without touching
    PORT, NEXT_PUBLIC_*, or other non-database vars. Also runs
    WT_POST_CREATE if set (e.g. schema migrations).

    With no argument, operates on the current worktree. Use --all to
    initialize all worktrees.

    Examples:
      wt db-init              # current worktree
      wt db-init --all        # all worktrees

  wt db-status

    Show database status for the current worktree across all active plugins.
    Displays database sizes, table counts, extensions, and other details.

DATABASE BACKUP & RESTORE

  wt db-backup [label]

    Dump all databases for the current worktree via active plugins.
    Backups are timestamped and stored under ~/.local/share/wt-backups/<id>/.
    An optional label (e.g. "before-migration") is saved alongside the backup
    for easy identification.

    Examples:
      wt db-backup                    # backup with timestamp only
      wt db-backup before-migration   # backup with a label

  wt db-restore [timestamp]

    Restore all databases for the current worktree from a previous backup.
    With no argument, opens an fzf picker to choose a backup. Accepts a
    timestamp directly to skip the picker. The target databases are dropped
    and recreated before restoring.

    Examples:
      wt db-restore                         # interactive picker
      wt db-restore 20260219-143000         # restore a specific backup
EOF
}

# Fetch a remote branch into the main worktree, trying Graphite first, then GitHub
# CLI, then plain git fetch. Leaves main on its original branch afterward. Sets
# FETCH_BRANCH to the local branch name that was checked out (gh pr checkout may rename).
# $1 = branch name
fetch_remote_branch() {
  local branch="$1"
  local main_dir
  main_dir=$(main_worktree_dir)
  local original_branch
  original_branch=$(git -C "$main_dir" rev-parse --abbrev-ref HEAD)
  local err_file
  err_file=$(mktemp)
  # Expand $err_file now so the trap cleans up the right file
  # shellcheck disable=SC2064
  trap "rm -f '$err_file'" RETURN

  FETCH_BRANCH="$branch"

  # Try Graphite first — gt get fetches the branch and its entire stack.
  # Use --no-checkout so gt doesn't try to switch branches in the main worktree
  # (which fails if there are uncommitted changes).
  if command -v gt &>/dev/null; then
    echo -e "${BOLD}Fetching branch via Graphite...${NC}"
    if (cd "$main_dir" && gt get "$branch" --force --no-checkout 2>"$err_file"); then
      return 0
    fi
    echo -e "${YELLOW}Graphite failed: $(cat "$err_file")${NC}"
  fi

  # Fall back to gh pr checkout
  if command -v gh &>/dev/null; then
    echo -e "${BOLD}Fetching branch via GitHub CLI...${NC}"
    if (cd "$main_dir" && gh pr checkout "$branch" --force 2>"$err_file"); then
      FETCH_BRANCH=$(git -C "$main_dir" rev-parse --abbrev-ref HEAD)
      (cd "$main_dir" && git checkout "$original_branch" > /dev/null 2>&1)
      return 0
    fi
    echo -e "${YELLOW}GitHub CLI failed: $(cat "$err_file")${NC}"
  fi

  # Last resort: plain git fetch
  echo -e "${BOLD}Fetching branch via git...${NC}"
  if git -C "$main_dir" fetch origin "$branch" 2>/dev/null; then
    if git -C "$main_dir" branch --list "$branch" | grep -q .; then
      # Local branch exists — update it to match remote
      git -C "$main_dir" branch -f "$branch" "origin/$branch" 2>/dev/null
    fi
    return 0
  fi

  return 1
}

cmd_create() {
  local branch=""
  local detach=false

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --detach)
        detach=true
        shift
        ;;
      -*)
        echo -e "${RED}Unknown option: $1${NC}"
        usage
        ;;
      *)
        if [[ -n "$branch" ]]; then
          echo -e "${RED}Unexpected argument: $1${NC}"
          usage
        fi
        branch="$1"
        shift
        ;;
    esac
  done

  if [[ -z "$branch" ]] && [[ "$detach" == false ]]; then
    echo -e "${RED}Error: branch name required${NC}"
    echo ""
    echo "Usage: wt create <branch>    Create worktree on a branch"
    echo "       wt create --detach    Create worktree in detached HEAD state"
    exit 1
  fi

  if [[ -n "$branch" ]] && [[ "$detach" == true ]]; then
    echo -e "${RED}Error: cannot specify both a branch and --detach${NC}"
    exit 1
  fi

  local n
  n=$(next_worktree_number)
  local wt_id="wt${n}"
  local wt_dir
  wt_dir=$(worktree_dir_for_number "$n")
  local port
  port=$(compute_port "$n")

  if [[ "$detach" == true ]]; then
    echo -e "${BOLD}Creating worktree ${wt_id} (detached)${NC}"
  else
    echo -e "${BOLD}Creating worktree ${wt_id} for branch '${branch}'${NC}"
  fi
  echo ""

  # Create git worktree
  echo -e "${GREEN}Git worktree:${NC} $wt_dir"
  if [[ "$detach" == true ]]; then
    git worktree add "$wt_dir" --detach
  else
    git fetch origin "$branch" 2>/dev/null || true
    git worktree add "$wt_dir" "$branch" 2>/dev/null \
      || git worktree add "$wt_dir" "origin/$branch" 2>/dev/null \
      || git worktree add "$wt_dir" -b "$branch"
  fi

  # Run plugin create hooks (clone databases, etc.)
  echo ""
  wt_dispatch_hook create "$wt_id"

  # Copy main .env then apply worktree-specific vars
  local main_env
  main_env=$(env_file_for "$(main_worktree_dir)")
  local wt_env
  wt_env=$(env_file_for "$wt_dir")
  if [[ -f "$main_env" ]]; then
    mkdir -p "$(dirname "$wt_env")"
    cp "$main_env" "$wt_env"
    echo -e "${GREEN}Copied .env from main${NC}"
  fi
  write_env_vars "$wt_env" "$wt_id" "$port"
  echo -e "${GREEN}Updated env vars in .env${NC}"

  # Write .env.agent with plugin-provided agent env vars
  write_agent_env "$wt_dir" "$wt_id"

  # Run project-specific post-create command (e.g. schema migrations)
  if [[ -n "${WT_POST_CREATE:-}" ]]; then
    echo ""
    echo -e "${BOLD}Running post-create...${NC}"
    (cd "$wt_dir" && eval "$WT_POST_CREATE")
  fi

  # Track branch in Graphite
  if [[ -n "$branch" ]] && command -v gt &>/dev/null; then
    echo ""
    echo -e "${BOLD}Tracking branch in Graphite...${NC}"
    local pr_base=""
    if command -v gh &>/dev/null; then
      pr_base=$(gh pr view "$branch" --json baseRefName --jq '.baseRefName' 2>/dev/null) || true
    fi
    if [[ -n "${pr_base:-}" ]]; then
      echo -e "  PR targets: ${pr_base}"
      (cd "$wt_dir" && git rebase "origin/${pr_base}" 2>/dev/null; gt branch track --force --parent "$pr_base" 2>/dev/null) \
        && echo -e "${GREEN}Tracked in Graphite (parent: ${pr_base})${NC}" \
        || echo -e "${YELLOW}Graphite tracking skipped${NC}"
    else
      (cd "$wt_dir" && gt branch track --force 2>/dev/null) \
        && echo -e "${GREEN}Tracked in Graphite${NC}" \
        || echo -e "${YELLOW}Graphite tracking skipped (no PR found, used nearest ancestor)${NC}"
    fi
  fi

  echo ""
  echo -e "${BOLD}Ready!${NC}"

  # Write path for shell wrapper to pick up for cd
  echo "$wt_dir" > /tmp/wt_cd_path
}

cmd_checkout() {
  local branch="${1:-}"

  if ! command -v gh &>/dev/null; then
    echo -e "${RED}gh CLI is required. Install it first.${NC}"
    exit 1
  fi

  if [[ -z "$branch" ]]; then
    if ! command -v fzf &>/dev/null; then
      echo -e "${RED}fzf is required for interactive selection.${NC}"
      exit 1
    fi

    # Verify gh authentication
    gh api user --jq '.login' 2>/dev/null > /dev/null || {
      echo -e "${RED}Not authenticated with gh. Run 'gh auth login' first.${NC}"
      exit 1
    }

    echo -e "${BOLD}Fetching your remote branches...${NC}"
    git fetch --prune origin > /dev/null 2>&1

    # Get branches already checked out in worktrees
    local wt_branches
    wt_branches=$(git worktree list --porcelain | awk '/^branch / { sub(/^refs\/heads\//, "", $2); print $2 }')

    # List remote branches excluding those already in a worktree and HEAD
    local branches
    branches=$(
      git for-each-ref \
        --sort=-committerdate \
        --format='%(refname:short)|%(authorname)|%(authoremail)|%(committerdate:relative)|%(subject)' \
        refs/remotes/origin/ \
      | grep -v '^origin/HEAD' \
      | while IFS='|' read -r ref _author _email date subject; do
          local b="${ref#origin/}"

          # Skip branches already in a worktree
          if echo "$wt_branches" | grep -qx "$b"; then
            continue
          fi

          echo "${b}|${date}|${subject}"
        done
    )

    # Filter to branches owned by the GitHub user using gh pr list
    local pr_branches
    pr_branches=$(gh pr list --author "@me" --state all --limit 100 --json headRefName --jq '.[].headRefName' 2>/dev/null)

    # Build the selectable list: branches that have a PR by this user
    local selectable
    selectable=$(
      echo "$branches" | while IFS='|' read -r b date subject; do
        [[ -z "$b" ]] && continue
        if echo "$pr_branches" | grep -qx "$b"; then
          printf "%-40s %-20s %s\n" "$b" "$date" "$subject"
        fi
      done
    )

    if [[ -z "$selectable" ]]; then
      echo -e "${YELLOW}No remote branches found with your PRs that aren't already worktrees.${NC}"
      exit 0
    fi

    # Let user pick
    local selection
    selection=$(echo "$selectable" | fzf --prompt="Check out branch: " --header="BRANCH                                   UPDATED              SUBJECT") || exit 0

    branch=$(echo "$selection" | awk '{print $1}')

    if [[ -z "$branch" ]]; then
      echo "No branch selected."
      exit 0
    fi

    echo ""
  fi

  # Fetch branch via Graphite or GitHub CLI, then create worktree
  FETCH_BRANCH=""
  if fetch_remote_branch "$branch"; then
    cmd_create "$FETCH_BRANCH"
  else
    echo -e "${RED}Failed to fetch branch: ${branch}${NC}"
    exit 1
  fi
}

remove_one() {
  local n="$1"
  local wt_id="wt${n}"
  local wt_dir
  wt_dir=$(worktree_dir_for_number "$n")

  echo -e "${BOLD}Removing worktree ${wt_id}${NC}"
  echo ""

  # Remove git worktree
  if git worktree list --porcelain | grep -q "^worktree ${wt_dir}$"; then
    echo -e "${YELLOW}Removing worktree:${NC} $wt_dir"
    git worktree remove "$wt_dir" --force
  else
    echo "Worktree directory not found in git, skipping git worktree remove."
    if [[ -d "$wt_dir" ]]; then
      rm -rf "$wt_dir"
    fi
  fi

  # Run plugin remove hooks (drop databases, etc.)
  echo ""
  wt_dispatch_hook remove "$wt_id"

  echo ""
  echo -e "${BOLD}Done.${NC}"
}

cmd_remove() {
  local arg="${1:-}"
  local n=""

  if [[ "$arg" == "--merged" ]]; then
    if ! command -v gh &>/dev/null; then
      echo -e "${RED}gh CLI is required. Install it first.${NC}"
      exit 1
    fi

    local lines
    if ! lines=$(merged_worktrees); then
      echo -e "${YELLOW}No worktrees with merged PRs found.${NC}"
      exit 0
    fi

    # Split into clean and dirty worktrees
    local -a clean_nums=() clean_branches=() skipped=()
    while IFS=$'\t' read -r num branch; do
      local wt_dir
      wt_dir=$(worktree_dir_for_number "$num")
      if [[ -n "$(git -C "$wt_dir" status --porcelain 2>/dev/null)" ]]; then
        skipped+=("wt${num}\t${branch}")
      else
        clean_nums+=("$num")
        clean_branches+=("$branch")
      fi
    done <<< "$lines"

    if [[ ${#skipped[@]} -gt 0 ]]; then
      echo -e "${YELLOW}Skipping worktrees with uncommitted changes:${NC}"
      for s in "${skipped[@]}"; do
        echo -e "  ${s}"
      done
      echo ""
    fi

    if [[ ${#clean_nums[@]} -eq 0 ]]; then
      echo -e "${YELLOW}No clean worktrees with merged PRs to remove.${NC}"
      exit 0
    fi

    echo -e "${BOLD}Worktrees to remove:${NC}"
    for i in "${!clean_nums[@]}"; do
      echo -e "  ${GREEN}wt${clean_nums[$i]}${NC}\t${clean_branches[$i]}"
    done
    echo ""

    read -rp "Remove all of these? [y/N] " confirm
    if [[ "$confirm" != [yY] ]]; then
      echo "Aborted."
      exit 0
    fi

    echo ""
    for n in "${clean_nums[@]}"; do
      remove_one "$n"
      echo ""
    done
    return
  fi

  if [[ -z "$arg" ]]; then
    # Interactive picker
    if ! command -v fzf &>/dev/null; then
      echo -e "${RED}fzf is required for interactive selection, or pass a worktree number.${NC}"
      exit 1
    fi

    local main_dir
    main_dir=$(main_worktree_dir)
    local repo
    repo=$(repo_name)
    local main_head
    main_head=$(git -C "$main_dir" rev-parse HEAD 2>/dev/null)

    # Build a wt list-style table of wtN worktrees for the picker
    local -a wt_paths=() wt_commits=() wt_branches=()
    local cur_wt="" cur_commit="" cur_branch=""

    while IFS= read -r line; do
      case "$line" in
        worktree\ *) cur_wt="${line#worktree }" ;;
        HEAD\ *)     cur_commit="${line#HEAD }" ;;
        branch\ *)   cur_branch="${line#branch refs/heads/}" ;;
        detached)    cur_branch="(detached)" ;;
        "")
          if [[ -n "$cur_wt" ]]; then
            wt_paths+=("$cur_wt")
            wt_commits+=("$cur_commit")
            wt_branches+=("$cur_branch")
          fi
          cur_wt="" cur_commit="" cur_branch=""
          ;;
      esac
    done < <(git worktree list --porcelain; echo "")

    {
      for i in "${!wt_paths[@]}"; do
        local wt="${wt_paths[$i]}"
        local commit="${wt_commits[$i]}"
        local branch="${wt_branches[$i]}"
        local dir_name
        dir_name=$(basename "$wt")

        # Only show wtN worktrees, not main
        if [[ "$dir_name" =~ ^${repo}-wt([0-9]+)$ ]]; then
          local wt_num="${BASH_REMATCH[1]}"
          local id="wt${wt_num}"
          local port=$((3000 + wt_num))

          # Build status: behind/ahead main + dirty indicators
          local status=""
          if [[ "$branch" != "(detached)" && -n "$main_head" ]]; then
            local behind ahead
            behind=$(git -C "$wt" rev-list --count "$commit..$main_head" 2>/dev/null) || behind=0
            ahead=$(git -C "$wt" rev-list --count "$main_head..$commit" 2>/dev/null) || ahead=0
            (( behind )) && status+="⇣${behind}" || true
            (( ahead )) && status+="⇡${ahead}" || true
          fi

          local staged=0 unstaged=0 untracked=0
          while IFS= read -r sline; do
            [[ -z "$sline" ]] && continue
            local xy="${sline:0:2}"
            if [[ "$xy" == "??" ]]; then
              (( ++untracked ))
            else
              [[ "${xy:0:1}" != " " && "${xy:0:1}" != "?" ]] && (( ++staged )) || true
              [[ "${xy:1:1}" != " " && "${xy:1:1}" != "?" ]] && (( ++unstaged )) || true
            fi
          done < <(git -C "$wt" status --porcelain 2>/dev/null)
          (( staged ))    && status+="+${staged}" || true
          (( unstaged ))  && status+="!${unstaged}" || true
          (( untracked )) && status+="?${untracked}" || true

          # Truncate long branch names
          local display_branch="$branch"
          if (( ${#display_branch} > 30 )); then
            display_branch="${display_branch:0:29}…"
          fi

          printf "%s\t%s\t%s\t%s\t%s\n" "$id" "$display_branch" "$port" "$status" "${commit:0:7}"
        fi
      done
    } > /tmp/wt_remove_list.$$ || true

    if [[ ! -s /tmp/wt_remove_list.$$ ]]; then
      echo -e "${YELLOW}No worktrees to remove.${NC}"
      rm -f /tmp/wt_remove_list.$$
      exit 0
    fi

    local formatted
    formatted=$({ printf "%s\t%s\t%s\t%s\t%s\n" "ID" "BRANCH" "PORT" "STATUS" "COMMIT"; cat /tmp/wt_remove_list.$$; } | $COLUMN -t -s $'\t')

    local header
    header=$(head -1 <<< "$formatted")
    formatted=$(tail -n +2 <<< "$formatted")

    local selection
    selection=$(echo "$formatted" | fzf --prompt="Remove worktree: " --header="$header") || {
      rm -f /tmp/wt_remove_list.$$
      exit 0
    }
    rm -f /tmp/wt_remove_list.$$

    n=$(echo "$selection" | awk '{print $1}' | sed 's/^wt//')
  else
    # Parse arg: accept "3" or "wt3"
    n="${arg#wt}"
    if ! [[ "$n" =~ ^[0-9]+$ ]]; then
      echo -e "${RED}Invalid worktree identifier: ${arg}${NC}"
      echo "Usage: wt remove [N|wtN]"
      exit 1
    fi
  fi

  local wt_id="wt${n}"
  local wt_dir
  wt_dir=$(worktree_dir_for_number "$n")

  if [[ ! -d "$wt_dir" ]]; then
    echo -e "${RED}Worktree directory not found: ${wt_dir}${NC}"
    exit 1
  fi

  # Gather branch info
  local branch=""
  while IFS= read -r line; do
    case "$line" in
      worktree\ "${wt_dir}") local found=1 ;;
      branch\ *)   [[ "${found:-}" == "1" ]] && branch="${line#branch refs/heads/}" ;;
      detached)    [[ "${found:-}" == "1" ]] && branch="(detached)" ;;
      "")          [[ "${found:-}" == "1" ]] && break ;;
    esac
  done < <(git worktree list --porcelain; echo "")

  # Check PR merge status
  local pr_status=""
  if [[ -n "$branch" && "$branch" != "(detached)" ]] && command -v gh &>/dev/null; then
    local pr_state
    pr_state=$(gh pr view "$branch" --json state --jq '.state' 2>/dev/null) || true
    case "$pr_state" in
      MERGED) pr_status="${GREEN}PR merged${NC}" ;;
      OPEN)   pr_status="${YELLOW}PR open${NC}" ;;
      CLOSED) pr_status="${YELLOW}PR closed (not merged)${NC}" ;;
      *)      pr_status="no PR found" ;;
    esac
  fi

  # Check dirty state
  local staged=0 unstaged=0 untracked=0
  while IFS= read -r sline; do
    [[ -z "$sline" ]] && continue
    local xy="${sline:0:2}"
    if [[ "$xy" == "??" ]]; then
      (( ++untracked ))
    else
      [[ "${xy:0:1}" != " " && "${xy:0:1}" != "?" ]] && (( ++staged )) || true
      [[ "${xy:1:1}" != " " && "${xy:1:1}" != "?" ]] && (( ++unstaged )) || true
    fi
  done < <(git -C "$wt_dir" status --porcelain 2>/dev/null)

  # Display summary
  echo -e "${BOLD}Worktree:${NC}  ${wt_id}"
  echo -e "${BOLD}Branch:${NC}   ${branch:-"(unknown)"}"
  [[ -n "$pr_status" ]] && echo -e "${BOLD}PR:${NC}       ${pr_status}"
  echo -e "${BOLD}Path:${NC}     ${wt_dir}"

  local dirty=0
  if (( staged || unstaged || untracked )); then
    dirty=1
    local status_parts=()
    (( staged ))    && status_parts+=("${staged} staged")
    (( unstaged ))  && status_parts+=("${unstaged} unstaged")
    (( untracked )) && status_parts+=("${untracked} untracked")
    echo -e "${BOLD}Status:${NC}   ${YELLOW}$(IFS=', '; echo "${status_parts[*]}")${NC}"
  else
    echo -e "${BOLD}Status:${NC}   clean"
  fi

  echo ""
  if (( dirty )); then
    echo -e "${RED}Warning: this will delete uncommitted changes and untracked files.${NC}"
  fi

  read -rp "Remove ${wt_id}? [y/N] " confirm
  if [[ "$confirm" != [yY] ]]; then
    echo "Aborted."
    exit 0
  fi

  echo ""
  remove_one "$n"
}

cmd_list() {
  local main_dir
  main_dir=$(main_worktree_dir)
  local repo
  repo=$(repo_name)
  local main_head
  main_head=$(git -C "$main_dir" rev-parse HEAD 2>/dev/null)

  # Parse git worktree list --porcelain into arrays
  local -a wt_paths=() wt_commits=() wt_branches=()
  local cur_wt="" cur_commit="" cur_branch=""

  while IFS= read -r line; do
    case "$line" in
      worktree\ *) cur_wt="${line#worktree }" ;;
      HEAD\ *)     cur_commit="${line#HEAD }" ;;
      branch\ *)   cur_branch="${line#branch refs/heads/}" ;;
      detached)    cur_branch="(detached)" ;;
      "")
        if [[ -n "$cur_wt" ]]; then
          wt_paths+=("$cur_wt")
          wt_commits+=("$cur_commit")
          wt_branches+=("$cur_branch")
        fi
        cur_wt="" cur_commit="" cur_branch=""
        ;;
    esac
  done < <(git worktree list --porcelain; echo "")

  {
    printf "ID\tDIRECTORY\tBRANCH\tPORT\tSTATUS\tCOMMIT\n"

    for i in "${!wt_paths[@]}"; do
      local wt="${wt_paths[$i]}"
      local commit="${wt_commits[$i]}"
      local branch="${wt_branches[$i]}"
      local dir_name id port

      dir_name=$(basename "$wt")

      if [[ "$wt" == "$main_dir" ]]; then
        id="main"
        port="3000"
      elif [[ "$dir_name" =~ ^${repo}-wt([0-9]+)$ ]]; then
        id="wt${BASH_REMATCH[1]}"
        port=$((3000 + BASH_REMATCH[1]))
      else
        id="old"
        port="?"
      fi

      # Build status: behind/ahead main + dirty indicators
      local status=""
      local wt_head="$commit"

      if [[ "$wt" != "$main_dir" && "$branch" != "(detached)" && -n "$main_head" ]]; then
        local behind ahead
        behind=$(git -C "$wt" rev-list --count "$wt_head..$main_head" 2>/dev/null) || behind=0
        ahead=$(git -C "$wt" rev-list --count "$main_head..$wt_head" 2>/dev/null) || ahead=0
        (( behind )) && status+="⇣${behind}" || true
        (( ahead )) && status+="⇡${ahead}" || true
      fi

      # Dirty state: staged, unstaged, untracked
      local staged=0 unstaged=0 untracked=0
      while IFS= read -r sline; do
        [[ -z "$sline" ]] && continue
        local xy="${sline:0:2}"
        if [[ "$xy" == "??" ]]; then
          (( ++untracked ))
        else
          [[ "${xy:0:1}" != " " && "${xy:0:1}" != "?" ]] && (( ++staged )) || true
          [[ "${xy:1:1}" != " " && "${xy:1:1}" != "?" ]] && (( ++unstaged )) || true
        fi
      done < <(git -C "$wt" status --porcelain 2>/dev/null)
      (( staged ))    && status+="+${staged}" || true
      (( unstaged ))  && status+="!${unstaged}" || true
      (( untracked )) && status+="?${untracked}" || true

      # Abbreviate directory
      local display_dir="$wt"
      if [[ "$display_dir" == "$HOME"* ]]; then
        display_dir="~${display_dir#"$HOME"}"
      fi
      local IFS_save="$IFS"
      IFS='/' read -ra parts <<< "$display_dir"
      IFS="$IFS_save"
      local n=${#parts[@]}
      local result="${parts[0]}"
      for (( j=1; j<n-1; j++ )); do
        result+="/${parts[$j]:0:1}"
      done
      (( n > 1 )) && result+="/${parts[$n-1]}"
      display_dir="$result"

      # Check for proxy domain
      local wt_env_file
      wt_env_file=$(env_file_for "$wt")
      local proxy
      proxy=$(read_proxy_domain "$wt_env_file")
      if [[ -n "$proxy" ]]; then
        status="${status:+${status} }proxy"
      fi

      # Truncate long branch names
      if (( ${#branch} > 30 )); then
        branch="${branch:0:29}…"
      fi

      printf "%s\t%s\t%s\t%s\t%s\t%s\n" "$id" "$display_dir" "$branch" "$port" "$status" "${commit:0:7}"
    done
  } | $COLUMN -t -s $'\t' | {
    IFS= read -r header
    echo -e "${BOLD}${header}${NC}"
    cat
  }
}

# Compute port from a target name: main=3000, N or wtN=3000+N
proxy_target_to_port() {
  local target="$1"
  case "$target" in
    main) echo 3000 ;;
    *)
      local n="${target#wt}"
      echo $((3000 + n))
      ;;
  esac
}

cmd_proxy() {
  local upstream_host="localhost"
  local explicit_domain=""

  # Parse flags
  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --help|-h)
        cat <<'HELP'
Usage: wt proxy [--host <host>] [--domain <domain>] [N|wtN|off]

Route the HTTPS proxy to a worktree's port via Caddy.

Local mode (default): moves PROXY_DOMAIN between worktree .env files
so only one worktree at a time has it. Domain is read from .env.

Remote mode (--host): Caddy-only, no .env management. Use this from
a Mac to route to a dev VM. Reads domain from .env if available, or
use --domain to specify it explicitly.

Examples:
  wt proxy 6                          # local: route to wt6
  wt proxy main                       # local: route to main
  wt proxy off                        # stop proxy
  wt proxy                            # show current routing
  wt proxy --host fw 6                # remote: route to fw:3006
  wt proxy --host fw --domain d.test 6  # remote: explicit domain
HELP
        return
        ;;
      --host)
        upstream_host="${2:-}"
        if [[ -z "$upstream_host" ]]; then
          echo -e "${RED}--host requires a value${NC}" >&2
          exit 1
        fi
        shift 2
        ;;
      --domain)
        explicit_domain="${2:-}"
        if [[ -z "$explicit_domain" ]]; then
          echo -e "${RED}--domain requires a value${NC}" >&2
          exit 1
        fi
        shift 2
        ;;
      *)
        echo -e "${RED}Unknown option: $1${NC}" >&2
        exit 1
        ;;
    esac
  done

  local target="${1:-}"
  local listen_port=5443
  local remote_mode=false
  [[ "$upstream_host" != "localhost" ]] && remote_mode=true

  # ---------- Remote mode: Caddy-only, no worktree/env management ----------
  if [[ "$remote_mode" == true ]]; then
    if [[ "$target" == "off" ]] || [[ -z "$target" && -z "$explicit_domain" ]]; then
      caddy_stop
      echo "Proxy stopped."
      return
    fi

    if [[ -z "$target" ]]; then
      echo -n "Proxy: "; caddy_status
      return
    fi

    # Normalize: accept "6" or "wt6"
    if [[ "$target" =~ ^[0-9]+$ ]]; then
      target="wt${target}"
    fi
    if [[ "$target" != "main" ]] && ! [[ "$target" =~ ^wt[0-9]+$ ]]; then
      echo -e "${RED}Unknown target: ${target}${NC}"
      echo "Use: main, wt1, wt2, ... or off"
      exit 1
    fi

    local domain="$explicit_domain"
    if [[ -z "$domain" ]]; then
      # Try to read from .env if we're in a repo
      local env_file
      env_file=$(env_file_for "$(main_worktree_dir 2>/dev/null)" 2>/dev/null) || true
      if [[ -n "$env_file" ]]; then
        domain=$(read_proxy_domain "$env_file")
      fi
    fi
    if [[ -z "$domain" ]]; then
      echo -e "${RED}No domain. Use --domain <domain> or set PROXY_DOMAIN in .env.${NC}"
      exit 1
    fi

    local target_port
    target_port=$(proxy_target_to_port "$target")
    caddy_write_config "$domain" "$listen_port" "$upstream_host" "$target_port"
    caddy_start "$domain"
    echo -e "${GREEN}https://${domain}:${listen_port}${NC} → ${upstream_host}:${target_port}"
    return
  fi

  # ---------- Local mode: manage PROXY_DOMAIN in worktree .env files ----------
  local main_dir
  main_dir=$(main_worktree_dir)
  local repo
  repo=$(repo_name)
  local parent_dir
  parent_dir=$(dirname "$main_dir")

  # Collect all worktrees: (id, dir, port) tuples
  local -a all_ids=() all_dirs=() all_ports=()

  all_ids+=("main")
  all_dirs+=("$main_dir")
  all_ports+=("3000")

  for dir in "$parent_dir/${repo}"-wt[0-9]*; do
    [[ -d "$dir" ]] || continue
    local name
    name=$(basename "$dir")
    local num="${name#"${repo}-wt"}"
    if [[ "$num" =~ ^[0-9]+$ ]]; then
      all_ids+=("wt${num}")
      all_dirs+=("$dir")
      all_ports+=("$((3000 + num))")
    fi
  done

  # No argument: show which worktree has the proxy
  if [[ -z "$target" ]]; then
    local found=false
    for i in "${!all_ids[@]}"; do
      local env_file
      env_file=$(env_file_for "${all_dirs[$i]}")
      local domain
      domain=$(read_proxy_domain "$env_file")
      if [[ -n "$domain" ]]; then
        echo -e "${GREEN}${all_ids[$i]}${NC} → ${domain}"
        found=true
      fi
    done
    if [[ "$found" == false ]]; then
      echo -e "${YELLOW}No worktree has PROXY_DOMAIN set.${NC}"
    fi
    return
  fi

  # "off": clear from all
  if [[ "$target" == "off" ]]; then
    for i in "${!all_ids[@]}"; do
      local env_file
      env_file=$(env_file_for "${all_dirs[$i]}")
      local domain
      domain=$(read_proxy_domain "$env_file")
      if [[ -n "$domain" ]]; then
        clear_proxy_domain "$env_file" "${all_ports[$i]}"
        echo -e "${YELLOW}${all_ids[$i]}${NC} cleared"
      fi
    done
    caddy_stop
    echo "Proxy stopped."
    return
  fi

  # Normalize: accept "6" or "wt6"
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    target="wt${target}"
  fi

  # Resolve target to index
  local target_idx=""
  for i in "${!all_ids[@]}"; do
    if [[ "${all_ids[$i]}" == "$target" ]]; then
      target_idx="$i"
      break
    fi
  done

  if [[ -z "$target_idx" ]]; then
    echo -e "${RED}Unknown worktree: ${target}${NC}"
    echo "Use: main, wt1, wt2, ... or off"
    exit 1
  fi

  # Find the proxy domain value (from whoever currently has it, or main's .env)
  local domain="$explicit_domain"
  if [[ -z "$domain" ]]; then
    for i in "${!all_ids[@]}"; do
      local env_file
      env_file=$(env_file_for "${all_dirs[$i]}")
      domain=$(read_proxy_domain "$env_file")
      [[ -n "$domain" ]] && break
    done
  fi

  if [[ -z "$domain" ]]; then
    echo -e "${RED}No PROXY_DOMAIN found in any worktree's .env.${NC}"
    echo "Add PROXY_DOMAIN=<domain> to your main .env first."
    exit 1
  fi

  # Clear from all, set on target
  for i in "${!all_ids[@]}"; do
    local env_file
    env_file=$(env_file_for "${all_dirs[$i]}")
    if [[ "$i" == "$target_idx" ]]; then
      set_proxy_domain "$env_file" "$domain"
    else
      local prev
      prev=$(read_proxy_domain "$env_file")
      if [[ -n "$prev" ]]; then
        clear_proxy_domain "$env_file" "${all_ports[$i]}"
      fi
    fi
  done

  # Start/reload Caddy to route to the target worktree
  local target_port="${all_ports[$target_idx]}"
  caddy_write_config "$domain" "$listen_port" "$upstream_host" "$target_port"
  caddy_start "$domain"
  echo -e "${GREEN}https://${domain}:${listen_port}${NC} → ${upstream_host}:${target_port}"
}

cmd_main() {
  echo "$(main_worktree_dir)"
}

cmd_switch() {
  local arg="${1:-}"

  if [[ -n "$arg" ]]; then
    # Direct switch: accept "3" or "wt3" or "main"
    if [[ "$arg" == "main" ]]; then
      echo "$(main_worktree_dir)"
      return
    fi

    local n="${arg#wt}"
    if ! [[ "$n" =~ ^[0-9]+$ ]]; then
      echo "Invalid worktree identifier: ${arg}" >&2
      echo "Usage: wt switch [N|wtN|main]" >&2
      exit 1
    fi

    local wt_dir
    wt_dir=$(worktree_dir_for_number "$n")
    if [[ ! -d "$wt_dir" ]]; then
      echo "Worktree not found: wt${n}" >&2
      exit 1
    fi

    echo "$wt_dir"
    return
  fi

  if ! command -v fzf &>/dev/null; then
    echo "fzf is required for interactive switching. Install it or use 'cd' directly." >&2
    echo "" >&2
    cmd_list >&2
    exit 1
  fi

  local selection
  selection=$(git worktree list | fzf --prompt="Switch to worktree: " | awk '{print $1}')

  if [[ -n "$selection" ]]; then
    echo "$selection"
  fi
}

cmd_status() {
  local main_dir
  main_dir=$(main_worktree_dir)
  local wt_id
  wt_id=$(current_worktree_id)
  local wtrc="${main_dir}/.wtrc"
  local env_file
  env_file=$(env_file_for "$(git rev-parse --show-toplevel)")

  echo -e "${BOLD}wt status for ${wt_id}${NC}"
  echo ""

  # Worktree info
  echo -e "${BOLD}Worktree${NC}"
  echo "  ID:        $wt_id"
  echo "  Directory: $(git rev-parse --show-toplevel)"
  echo "  Branch:    $(git rev-parse --abbrev-ref HEAD)"
  echo "  Main:      $main_dir"
  echo ""

  # .wtrc / plugins — read directly without wt_load_plugins so status works
  # even when plugin prerequisites are missing.
  local -a status_plugins=()
  echo -e "${BOLD}Plugins${NC}"
  if [[ -f "$wtrc" ]]; then
    # Source .wtrc for WT_PLUGINS without loading plugin files.
    local WT_PLUGINS=()
    # shellcheck source=/dev/null
    source "$wtrc" 2>/dev/null || true
    status_plugins=("${WT_PLUGINS[@]}")
    echo -e "  .wtrc:     ${GREEN}found${NC} ${DIM}(${wtrc})${NC}"
    if [[ ${#status_plugins[@]} -gt 0 ]]; then
      echo "  Active:    ${status_plugins[*]}"
    else
      echo -e "  Active:    ${YELLOW}none — WT_PLUGINS is empty in .wtrc${NC}"
    fi
  else
    echo -e "  .wtrc:     ${YELLOW}not found${NC}"
    echo -e "  ${DIM}Create ${wtrc} to enable database plugins.${NC}"
    echo -e "  ${DIM}Run 'wt help' and see the PLUGINS section.${NC}"
  fi
  echo ""

  # Services — check based on configured plugins
  echo -e "${BOLD}Services${NC}"
  local has_pg=false has_ch=false
  if [[ ${#status_plugins[@]} -gt 0 ]]; then
    for p in "${status_plugins[@]}"; do
      [[ "$p" == "postgres" ]] && has_pg=true
      [[ "$p" == "clickhouse" ]] && has_ch=true
    done
  fi

  if $has_pg; then
    if command -v psql &>/dev/null; then
      if PGPASSWORD=postgres psql -U postgres -h localhost -p 5432 -tAc "SELECT 1" &>/dev/null; then
        local pg_version
        pg_version=$(PGPASSWORD=postgres psql -U postgres -h localhost -p 5432 -tAc "SHOW server_version;" 2>/dev/null) || pg_version="unknown"
        echo -e "  PostgreSQL: ${GREEN}running${NC} (${pg_version})"
      else
        echo -e "  PostgreSQL: ${RED}not responding${NC} on localhost:5432"
      fi
    else
      echo -e "  PostgreSQL: ${RED}psql not found${NC} — brew install postgresql"
    fi
  fi

  if $has_ch; then
    if command -v clickhouse &>/dev/null; then
      if clickhouse client --host localhost --port 9000 -q "SELECT 1" &>/dev/null; then
        local ch_version
        ch_version=$(clickhouse client --host localhost --port 9000 -q "SELECT version()" 2>/dev/null) || ch_version="unknown"
        echo -e "  ClickHouse: ${GREEN}running${NC} (${ch_version})"
      else
        echo -e "  ClickHouse: ${RED}not responding${NC} on localhost:9000"
      fi
    else
      echo -e "  ClickHouse: ${YELLOW}not installed${NC} — see https://clickhouse.com/docs/install"
    fi
  fi

  if ! $has_pg && ! $has_ch; then
    echo -e "  ${DIM}No database plugins configured.${NC}"
  fi
  echo ""

  # .env
  echo -e "${BOLD}Environment${NC}"
  if [[ -f "$env_file" ]]; then
    echo -e "  .env:      ${GREEN}found${NC} ${DIM}(${env_file})${NC}"
  else
    echo -e "  .env:      ${YELLOW}not found${NC} ${DIM}(${env_file})${NC}"
  fi
  echo ""

  # Database details — try loading plugins; skip if prerequisites are missing.
  if [[ ${#status_plugins[@]} -gt 0 ]]; then
    echo -e "${BOLD}Databases${NC}"
    if wt_load_plugins "$main_dir"; then
      wt_dispatch_hook status "$wt_id"
    fi
  fi
}

cmd_db_init() {
  if warn_no_plugins; then
    return
  fi

  local do_all=false
  [[ "${1:-}" == "--all" ]] && do_all=true

  local main_dir repo parent_dir
  main_dir=$(main_worktree_dir)
  repo=$(repo_name)
  parent_dir=$(dirname "$main_dir")

  local -a wt_dirs=() wt_ids=()

  if $do_all; then
    # Main worktree
    wt_dirs+=("$main_dir")
    wt_ids+=("main")
    # Numbered worktrees
    for dir in "$parent_dir/${repo}"-wt[0-9]*; do
      [[ -d "$dir" ]] || continue
      local name num
      name=$(basename "$dir")
      num="${name#"${repo}-wt"}"
      if [[ "$num" =~ ^[0-9]+$ ]]; then
        wt_dirs+=("$dir")
        wt_ids+=("wt${num}")
      fi
    done
  else
    local wt_id
    wt_id=$(current_worktree_id)
    wt_dirs+=("$(git rev-parse --show-toplevel)")
    wt_ids+=("$wt_id")
  fi

  for i in "${!wt_ids[@]}"; do
    local wt_id="${wt_ids[$i]}"
    local wt_dir="${wt_dirs[$i]}"
    local env_file
    env_file=$(env_file_for "$wt_dir")

    echo -e "${BOLD}${wt_id}${NC}"
    wt_dispatch_hook create "$wt_id"
    if [[ -f "$env_file" ]]; then
      wt_dispatch_hook env "$env_file" "$wt_id"
      echo -e "${GREEN}Updated database env vars${NC}"
    fi
    write_agent_env "$wt_dir" "$wt_id"
    if [[ -n "${WT_POST_CREATE:-}" ]]; then
      echo -e "${BOLD}Running post-create...${NC}"
      (cd "$wt_dir" && eval "$WT_POST_CREATE")
    fi
    echo ""
  done
}

cmd_db_status() {
  if warn_no_plugins; then
    return
  fi

  local wt_id
  wt_id=$(current_worktree_id)

  echo -e "${BOLD}Database status for ${wt_id}${NC}"
  echo ""
  wt_dispatch_hook status "$wt_id"
}

cmd_db_backup() {
  local label="${1:-}"
  local wt_id
  wt_id=$(current_worktree_id)
  local sanitized
  sanitized=$(wt_sanitize_name "$wt_id")
  local timestamp
  timestamp=$(date +%Y%m%d-%H%M%S)
  local backup_subdir="${WT_BACKUP_DIR}/${sanitized}/${timestamp}"

  mkdir -p "$backup_subdir"

  echo -e "${BOLD}Backing up databases for ${wt_id}${NC}"
  echo ""
  wt_dispatch_hook backup "$wt_id" "$backup_subdir"

  if [[ -n "$label" ]]; then
    echo "$label" > "${backup_subdir}/label"
  fi

  echo ""
  echo -e "==> Backup saved to ${backup_subdir}"
}

cmd_agent_env() {
  local wt_id
  wt_id=$(current_worktree_id)

  local wt_dir
  if [[ "$wt_id" == "main" ]]; then
    wt_dir=$(main_worktree_dir)
  else
    local n="${wt_id#wt}"
    wt_dir=$(worktree_dir_for_number "$n")
  fi

  write_agent_env "$wt_dir" "$wt_id"
}

cmd_env_sync() {
  local main_dir
  main_dir=$(main_worktree_dir)
  local main_env
  main_env=$(env_file_for "$main_dir")
  local repo
  repo=$(repo_name)
  local parent_dir
  parent_dir=$(dirname "$main_dir")

  if [[ ! -f "$main_env" ]]; then
    echo -e "${RED}Main .env not found: ${main_env}${NC}"
    exit 1
  fi

  local count=0

  for dir in "$parent_dir/${repo}"-wt[0-9]*; do
    [[ -d "$dir" ]] || continue
    local name
    name=$(basename "$dir")
    local num="${name#"${repo}-wt"}"
    if [[ "$num" =~ ^[0-9]+$ ]]; then
      local wt_id="wt${num}"
      local wt_env
      wt_env=$(env_file_for "$dir")
      local port
      port=$(compute_port "$num")

      # Preserve worktree-specific PROXY_DOMAIN across sync
      local prev_proxy
      prev_proxy=$(read_proxy_domain "$wt_env")
      cp "$main_env" "$wt_env"
      # Strip PROXY_DOMAIN copied from main — it's worktree-specific
      local tmp_sync
      tmp_sync=$(mktemp)
      grep -v '^PROXY_DOMAIN=' "$wt_env" > "$tmp_sync" || true
      mv "$tmp_sync" "$wt_env"
      # Restore if this worktree had it
      if [[ -n "$prev_proxy" ]]; then
        set_proxy_domain "$wt_env" "$prev_proxy"
      fi
      write_env_vars "$wt_env" "$wt_id" "$port"
      echo -e "${GREEN}${wt_id}${NC} → $wt_env"
      ((++count))
    fi
  done

  if [[ "$count" -eq 0 ]]; then
    echo -e "${YELLOW}No worktrees found to sync.${NC}"
  else
    echo ""
    echo -e "${BOLD}Synced .env to ${count} worktree(s) from main.${NC}"
  fi
}

# Print "number\tbranch" lines for each worktree whose PR has been merged.
# Requires gh CLI. Returns 1 if none found.
merged_worktrees() {
  local main_dir
  main_dir=$(main_worktree_dir)
  local repo
  repo=$(repo_name)

  local -a wt_paths=() wt_branches=()
  local cur_wt="" cur_branch=""

  while IFS= read -r line; do
    case "$line" in
      worktree\ *) cur_wt="${line#worktree }" ;;
      branch\ *)   cur_branch="${line#branch refs/heads/}" ;;
      detached)    cur_branch="" ;;
      "")
        if [[ -n "$cur_wt" ]]; then
          wt_paths+=("$cur_wt")
          wt_branches+=("$cur_branch")
        fi
        cur_wt="" cur_branch=""
        ;;
    esac
  done < <(git worktree list --porcelain; echo "")

  local found=0
  for i in "${!wt_paths[@]}"; do
    local wt="${wt_paths[$i]}"
    local branch="${wt_branches[$i]}"

    [[ "$wt" == "$main_dir" ]] && continue
    [[ -z "$branch" ]] && continue

    local dir_name
    dir_name=$(basename "$wt")
    if [[ "$dir_name" =~ ^${repo}-wt([0-9]+)$ ]]; then
      local num="${BASH_REMATCH[1]}"
      local pr_state
      pr_state=$(gh pr view "$branch" --json state --jq '.state' 2>/dev/null) || continue
      if [[ "$pr_state" == "MERGED" ]]; then
        echo -e "${num}\t${branch}"
        ((++found))
      fi
    fi
  done

  (( found )) || return 1
}

cmd_merged() {
  if ! command -v gh &>/dev/null; then
    echo -e "${RED}gh CLI is required. Install it first.${NC}"
    exit 1
  fi

  local lines
  if ! lines=$(merged_worktrees); then
    echo -e "${YELLOW}No worktrees with merged PRs found.${NC}"
    return
  fi

  while IFS=$'\t' read -r num branch; do
    local wt_dir
    wt_dir=$(worktree_dir_for_number "$num")
    if [[ -n "$(git -C "$wt_dir" status --porcelain 2>/dev/null)" ]]; then
      echo -e "${GREEN}wt${num}${NC}\t${branch}\t${YELLOW}(dirty)${NC}"
    else
      echo -e "${GREEN}wt${num}${NC}\t${branch}"
    fi
  done <<< "$lines"
}

cmd_db_restore() {
  local timestamp="${1:-}"
  local wt_id
  wt_id=$(current_worktree_id)
  local sanitized
  sanitized=$(wt_sanitize_name "$wt_id")
  local backup_dir="${WT_BACKUP_DIR}/${sanitized}"

  if [[ ! -d "$backup_dir" ]]; then
    echo -e "${RED}No backups found for ${wt_id}${NC}"
    exit 1
  fi

  if [[ -z "$timestamp" ]]; then
    # Interactive picker
    if ! command -v fzf &>/dev/null; then
      echo -e "${RED}fzf is required for interactive selection, or pass a timestamp.${NC}"
      echo ""
      echo "Available backups:"
      wt_list_backups "$wt_id"
      exit 1
    fi

    local listing
    listing=$(wt_list_backups "$wt_id")
    if [[ -z "$listing" ]]; then
      echo -e "${RED}No backups found for ${wt_id}${NC}"
      exit 1
    fi

    local selection
    selection=$(echo "$listing" | fzf --prompt="Restore backup: " --tac) || exit 0
    timestamp=$(echo "$selection" | awk '{print $1}')
  fi

  local backup_subdir="${backup_dir}/${timestamp}"
  if [[ ! -d "$backup_subdir" ]]; then
    echo -e "${RED}Backup not found: ${backup_subdir}${NC}"
    exit 1
  fi

  echo -e "${BOLD}Restoring databases for ${wt_id} from ${timestamp}${NC}"
  echo ""
  wt_dispatch_hook restore "$wt_id" "$backup_subdir"
}

cmd_ngrok() {
  local upstream_host="localhost"

  # Parse flags
  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --help|-h)
        cat <<HELP
Usage: wt ngrok [--host <host>] [N|wtN|off]

Tunnel a worktree's port via ngrok for external webhook access.

Local mode (default): tunnels to localhost:<port>.

Remote mode (--host): tunnels to <host>:<port>. Use this from a Mac
to route webhooks to a dev VM, centralizing all inbound routing.

Requires NGROK_DOMAIN in your environment (e.g. via ~/.zshenv.local):
  export NGROK_DOMAIN="your-domain.ngrok-free.app"

NGROK_DOMAIN: ${NGROK_DOMAIN:-(not set)}

Examples:
  wt ngrok 1                      # local: tunnel to wt1 (port 3001)
  wt ngrok main                   # local: tunnel to main (port 3000)
  wt ngrok off                    # stop ngrok
  wt ngrok                        # show status + detect orphans
  wt ngrok log                    # tail the ngrok log
  wt ngrok kill                   # kill all orphan ngrok processes
  wt ngrok --host fw 6            # remote: tunnel to fw:3006
HELP
        return
        ;;
      --host)
        upstream_host="${2:-}"
        if [[ -z "$upstream_host" ]]; then
          echo -e "${RED}--host requires a value${NC}" >&2
          exit 1
        fi
        shift 2
        ;;
      *)
        echo -e "${RED}Unknown option: $1${NC}" >&2
        exit 1
        ;;
    esac
  done

  local target="${1:-}"

  # No argument: show status
  if [[ -z "$target" ]]; then
    echo "ngrok:"
    ngrok_status
    return
  fi

  # "off": stop ngrok
  if [[ "$target" == "off" ]]; then
    ngrok_stop
    echo "ngrok stopped."
    local -a orphans=()
    while IFS= read -r pid; do
      [[ -n "$pid" ]] && orphans+=("$pid")
    done < <(ngrok_orphan_pids)
    if [[ ${#orphans[@]} -gt 0 ]]; then
      echo "Note: ${#orphans[@]} orphan ngrok process(es) still running. Use 'wt ngrok kill' to stop them."
    fi
    return
  fi

  # "log": tail the log file
  if [[ "$target" == "log" ]]; then
    if [[ -f "$NGROK_LOGFILE" ]]; then
      tail -f "$NGROK_LOGFILE"
    else
      echo "No log file yet. Start ngrok first."
    fi
    return
  fi

  # "kill": kill orphan ngrok processes
  if [[ "$target" == "kill" ]]; then
    local -a orphans=()
    while IFS= read -r pid; do
      [[ -n "$pid" ]] && orphans+=("$pid")
    done < <(ngrok_orphan_pids)
    if [[ ${#orphans[@]} -eq 0 ]]; then
      echo "No orphan ngrok processes found."
    else
      echo "Killing ${#orphans[@]} orphan ngrok process(es): ${orphans[*]}"
      kill "${orphans[@]}" 2>/dev/null || true
    fi
    return
  fi

  # Normalize: accept "6" or "wt6"
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    target="wt${target}"
  fi
  if [[ "$target" != "main" ]] && ! [[ "$target" =~ ^wt[0-9]+$ ]]; then
    echo -e "${RED}Unknown target: ${target}${NC}"
    echo "Use: main, wt1, wt2, ... or off"
    exit 1
  fi

  local target_port
  target_port=$(proxy_target_to_port "$target")

  ngrok_start "$upstream_host" "$target_port"

  if ! ngrok_wait_or_fail; then
    echo -e "${RED}ngrok failed to start${NC}" >&2
    return 1
  fi

  local domain
  domain=$(ngrok_domain)
  echo -e "${GREEN}https://${domain}${NC} → ${upstream_host}:${target_port}"
}

# --- Process status ---

# Abbreviate a path: ~ for $HOME, single-char intermediate segments
_ps_abbrev_path() {
  local dir="$1"
  if [[ "$dir" == "$HOME"* ]]; then
    dir="~${dir#"$HOME"}"
  fi
  local IFS_save="$IFS"
  IFS='/' read -ra parts <<< "$dir"
  IFS="$IFS_save"
  local n=${#parts[@]}
  local result="${parts[0]}"
  for (( j=1; j<n-1; j++ )); do
    result+="/${parts[$j]:0:1}"
  done
  (( n > 1 )) && result+="/${parts[$n-1]}"
  echo "$result"
}

# Return "mem uptime" summary for a process tree, or empty if pid gone
_ps_proc_summary() {
  local pid="$1"
  local rss _pct etime
  read -r rss _pct etime < <(ps -o rss=,%mem=,etime= -p "$pid" --no-headers 2>/dev/null) || return

  # Total RSS including children
  local total_rss=$rss child_rss cpid
  while IFS= read -r cpid; do
    [[ -z "$cpid" ]] && continue
    child_rss=$(ps -o rss= -p "$cpid" --no-headers 2>/dev/null) || continue
    total_rss=$((total_rss + child_rss))
  done < <(pgrep -P "$pid" 2>/dev/null)

  local mem
  if (( total_rss >= 1048576 )); then
    mem=$(awk "BEGIN{printf \"%.1fG\", $total_rss/1048576}")
  else
    mem=$(awk "BEGIN{printf \"%.0fM\", $total_rss/1024}")
  fi

  echo "${mem} ${etime}"
}

# Find a next-server process whose cwd is within the given directory
_ps_find_next_server() {
  local wt_dir="$1"
  local pids pid cwd
  pids=$(pgrep -f '^next-server ' 2>/dev/null || true)
  [[ -z "$pids" ]] && return
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null) || continue
    if [[ "$cwd" == "$wt_dir" || "$cwd" == "$wt_dir"/* ]]; then
      echo "$pid"
      return
    fi
  done <<< "$pids"
}

# Find an inngest dev process belonging to the given worktree directory.
# Locates the pnpm dev:inngest process by cwd, then walks to the leaf
# inngest binary for accurate resource measurement.
_ps_find_inngest() {
  local wt_dir="$1"
  local pids pid cwd
  pids=$(pgrep -f 'pnpm dev:inngest' 2>/dev/null || true)
  [[ -z "$pids" ]] && return
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null) || continue
    if [[ "$cwd" == "$wt_dir" || "$cwd" == "$wt_dir"/* ]]; then
      # Find the leaf inngest binary for accurate resource info
      local leaf="$pid"
      local children
      while true; do
        children=$(pgrep -P "$leaf" 2>/dev/null | head -1) || break
        [[ -z "$children" ]] && break
        leaf="$children"
      done
      echo "$leaf"
      return
    fi
  done <<< "$pids"
}

cmd_ps() {
  local show_all=false
  if [[ "${1:-}" == "--all" || "${1:-}" == "-a" ]]; then
    show_all=true
  fi

  local main_dir repo
  main_dir=$(main_worktree_dir)
  repo=$(repo_name)

  # Detect proxy/ngrok target ports once
  local proxy_port="" ngrok_port=""
  if caddy_is_running && [[ -f "$CADDYFILE" ]]; then
    proxy_port=$(sed -n 's/.*reverse_proxy [^:]*:\([0-9]*\).*/\1/p' "$CADDYFILE" 2>/dev/null || true)
  fi
  if ngrok_is_running; then
    local response
    response=$(curl -s "$NGROK_API/tunnels" 2>/dev/null) || true
    if [[ -n "$response" ]]; then
      ngrok_port=$(echo "$response" | sed -n 's/.*"addr" *: *"[^:]*:\([0-9]*\)".*/\1/p' | head -1 || true)
    fi
  fi

  # Build list of worktrees to report on
  local -a wt_paths=() wt_ids=() wt_ports=()

  if $show_all; then
    local cur_wt=""
    while IFS= read -r line; do
      case "$line" in
        worktree\ *) cur_wt="${line#worktree }" ;;
        "")
          if [[ -n "$cur_wt" ]]; then
            local dir_name id port
            dir_name=$(basename "$cur_wt")
            if [[ "$cur_wt" == "$main_dir" ]]; then
              id="main"; port="3000"
            elif [[ "$dir_name" =~ ^${repo}-wt([0-9]+)$ ]]; then
              id="wt${BASH_REMATCH[1]}"; port=$((3000 + BASH_REMATCH[1]))
            else
              id="$dir_name"; port="?"
            fi
            wt_paths+=("$cur_wt")
            wt_ids+=("$id")
            wt_ports+=("$port")
          fi
          cur_wt=""
          ;;
      esac
    done < <(git worktree list --porcelain; echo "")
  else
    local wt_id wt_dir port
    wt_id=$(current_worktree_id)
    wt_dir=$(git rev-parse --show-toplevel)
    if [[ "$wt_id" == "main" ]]; then
      port="3000"
    elif [[ "$wt_id" =~ ^wt([0-9]+)$ ]]; then
      port=$((3000 + BASH_REMATCH[1]))
    else
      port="?"
    fi
    wt_paths+=("$wt_dir")
    wt_ids+=("$wt_id")
    wt_ports+=("$port")
  fi

  # Collect rows
  local output=""
  output+="ID\tDIRECTORY\tPORT\tNEXT\tINNGEST$(wt_ps_headers)\tROUTING\n"

  for i in "${!wt_paths[@]}"; do
    local wt="${wt_paths[$i]}" id="${wt_ids[$i]}" port="${wt_ports[$i]}"
    local display_dir next_info inngest_info routing

    display_dir=$(_ps_abbrev_path "$wt")

    # next-server
    local next_pid
    next_pid=$(_ps_find_next_server "$wt")
    if [[ -n "$next_pid" ]]; then
      next_info=$(_ps_proc_summary "$next_pid")
    else
      next_info="-"
    fi

    # inngest
    local inngest_pid
    inngest_pid=$(_ps_find_inngest "$wt")
    if [[ -n "$inngest_pid" ]]; then
      inngest_info=$(_ps_proc_summary "$inngest_pid")
    else
      inngest_info="-"
    fi

    # routing
    routing=""
    [[ "$proxy_port" == "$port" ]] && routing+="proxy "
    [[ "$ngrok_port" == "$port" ]] && routing+="ngrok "
    routing="${routing:--}"

    output+="${id}\t${display_dir}\t${port}\t${next_info}\t${inngest_info}$(wt_ps_data "$id")\t${routing}\n"
  done

  printf "%b" "$output" | $COLUMN -t -s $'\t' | {
    IFS= read -r header
    echo -e "${BOLD}${header}${NC}"
    cat
  }
}

# --- Kill dev processes ---

# Kill a process and its entire process group.
# Sends SIGTERM to the process group, waits briefly, then SIGKILL if needed.
_kill_proc_tree() {
  local pid="$1" label="$2"
  local pgid
  pgid=$(ps -o pgid= -p "$pid" 2>/dev/null | tr -d ' ') || return

  echo -e "  ${label}: killing process group (pgid ${pgid})"
  kill -- -"$pgid" 2>/dev/null || kill "$pid" 2>/dev/null || true

  # Wait briefly for clean exit, then force-kill
  local i
  for i in 1 2 3; do
    kill -0 "$pid" 2>/dev/null || return
    sleep 0.5
  done
  kill -9 -- -"$pgid" 2>/dev/null || kill -9 "$pid" 2>/dev/null || true
}

# Find the pnpm dev:inngest parent process for a worktree (for killing, not the leaf)
_kill_find_inngest_parent() {
  local wt_dir="$1"
  local pids pid cwd
  pids=$(pgrep -f 'pnpm dev:inngest' 2>/dev/null || true)
  [[ -z "$pids" ]] && return
  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null) || continue
    if [[ "$cwd" == "$wt_dir" || "$cwd" == "$wt_dir"/* ]]; then
      echo "$pid"
      return
    fi
  done <<< "$pids"
}

cmd_kill() {
  local arg="${1:-}"

  if [[ -z "$arg" ]]; then
    echo -e "${RED}Usage: wt kill [N|wtN|main]${NC}"
    exit 1
  fi

  local wt_dir

  if [[ "$arg" == "main" ]]; then
    wt_dir=$(main_worktree_dir)
  else
    local n="${arg#wt}"
    if ! [[ "$n" =~ ^[0-9]+$ ]]; then
      echo -e "${RED}Invalid worktree identifier: ${arg}${NC}"
      echo "Usage: wt kill [N|wtN|main]"
      exit 1
    fi
    wt_dir=$(worktree_dir_for_number "$n")
  fi

  if [[ ! -d "$wt_dir" ]]; then
    echo -e "${RED}Worktree directory not found: ${wt_dir}${NC}"
    exit 1
  fi

  local killed=0

  # Kill Next.js
  local next_pid
  next_pid=$(_ps_find_next_server "$wt_dir")
  if [[ -n "$next_pid" ]]; then
    _kill_proc_tree "$next_pid" "Next.js"
    (( ++killed ))
  fi

  # Kill Inngest
  local inngest_pid
  inngest_pid=$(_kill_find_inngest_parent "$wt_dir")
  if [[ -n "$inngest_pid" ]]; then
    _kill_proc_tree "$inngest_pid" "Inngest"
    (( ++killed ))
  fi

  if (( killed == 0 )); then
    echo "No running processes found for ${arg}."
  else
    echo -e "${GREEN}Done.${NC}"
  fi
}

# --- Main dispatch ---

ensure_in_repo

[[ $# -lt 1 ]] && { cmd_help; exit 0; }

command="$1"
shift

# 'status' runs before plugin loading so it can diagnose config issues.
if [[ "$command" == "status" ]]; then
  cmd_status
  exit 0
fi

wt_load_plugins "$(main_worktree_dir)" || exit 1

case "$command" in
  create)     cmd_create "$@" ;;
  checkout)   cmd_checkout "$@" ;;
  remove)     cmd_remove "$@" ;;
  list)       cmd_list ;;
  main)       cmd_main ;;
  switch)     cmd_switch "$@" ;;
  env-sync)      cmd_env_sync ;;
  agent-env)     cmd_agent_env ;;
  proxy)         cmd_proxy "$@" ;;
  ngrok)      cmd_ngrok "$@" ;;
  db-init)    cmd_db_init "$@" ;;
  db-status)  cmd_db_status ;;
  db-backup)  cmd_db_backup "$@" ;;
  db-restore) cmd_db_restore "$@" ;;
  merged)     cmd_merged ;;
  ps)         cmd_ps "$@" ;;
  kill)        cmd_kill "$@" ;;
  help)       cmd_help ;;
  *)          echo "Unknown command: $command"; usage ;;
esac
