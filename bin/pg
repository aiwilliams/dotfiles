#!/usr/bin/env bash
# pg — Execute PostgreSQL queries using connection info from .env files.
#
# Usage:
#   pg [options] [sql]
#
# Options:
#   -e <path>    Path to .env file
#   -f <file>    Execute SQL from file
#
# .env discovery (in order):
#   1. Path given via -e
#   2. .env in current directory
#   3. apps/platform/.env from git root
#
# Examples:
#   pg "SELECT * FROM users LIMIT 5"
#   pg                              Open interactive psql session
#   pg -f schema.sql                Execute SQL from file
#   echo "SELECT 1" | pg            Pipe SQL via stdin

set -euo pipefail

usage() {
  cat <<'EOF'
Usage: pg [options] [sql]

Execute PostgreSQL queries using connection info from .env files.

Options:
  -e <path>    Path to .env file
  -f <file>    Execute SQL from file
  -h           Show this help

.env discovery (in order):
  1. Path given via -e
  2. .env in current directory
  3. apps/platform/.env from git root

Examples:
  pg "SELECT * FROM users LIMIT 5"
  pg                              Open interactive psql session
  pg -f schema.sql                Execute SQL from file
  echo "SELECT 1" | pg            Pipe SQL via stdin
EOF
  exit 0
}

env_file=""
sql_file=""

while getopts "e:f:h" opt; do
  case "$opt" in
    e) env_file="$OPTARG" ;;
    f) sql_file="$OPTARG" ;;
    h) usage ;;
    *) usage ;;
  esac
done
shift $((OPTIND - 1))

# --- Discover .env file ---

find_env_file() {
  if [[ -n "$env_file" ]]; then
    if [[ ! -f "$env_file" ]]; then
      echo "Error: .env file not found: $env_file" >&2
      exit 1
    fi
    return
  fi

  if [[ -f ".env" ]]; then
    env_file=".env"
    return
  fi

  local git_root
  git_root=$(git rev-parse --show-toplevel 2>/dev/null) || true
  if [[ -n "$git_root" && -f "$git_root/apps/platform/.env" ]]; then
    env_file="$git_root/apps/platform/.env"
    return
  fi

  echo "Error: No .env file found. Searched:" >&2
  echo "  .env (current directory)" >&2
  if [[ -n "${git_root:-}" ]]; then
    echo "  $git_root/apps/platform/.env" >&2
  fi
  echo "" >&2
  echo "Use -e <path> to specify a .env file." >&2
  exit 1
}

find_env_file

# --- Extract connection URL ---

# Read a single VAR="value" from the env file, stripping quotes. Returns an
# empty string (not a failure) when the var is absent, so callers under
# `set -e`/`pipefail` can probe for optional vars.
read_env_var() {
  local var="$1"
  grep "^${var}=" "$env_file" | head -1 | sed "s/^${var}=//" | tr -d '"' | tr -d "'" || true
}

# Prefer an explicit POSTGRES_URL if present; otherwise reconstruct one from the
# component parts (USER/PASSWORD/HOST/PORT/DATABASE). The main block no longer
# emits POSTGRES_URL — it is component-only so the app can derive it — so
# reconstruction is the normal path.
url=$(read_env_var "POSTGRES_URL")

if [[ -z "$url" ]]; then
  user=$(read_env_var "POSTGRES_USER")
  password=$(read_env_var "POSTGRES_PASSWORD")
  host=$(read_env_var "POSTGRES_HOST")
  port=$(read_env_var "POSTGRES_PORT")
  database=$(read_env_var "POSTGRES_DATABASE")

  if [[ -n "$user" && -n "$host" && -n "$database" ]]; then
    auth="$user"
    [[ -n "$password" ]] && auth="${user}:${password}"
    if [[ -n "$port" ]]; then
      url="postgresql://${auth}@${host}:${port}/${database}"
    else
      url="postgresql://${auth}@${host}/${database}"
    fi
  fi
fi

if [[ -z "$url" ]]; then
  echo "Error: could not resolve a connection URL in $env_file" >&2
  echo "  Looked for POSTGRES_URL, or POSTGRES_{USER,PASSWORD,HOST,PORT,DATABASE}." >&2
  exit 1
fi

# --- Execute ---

if [[ -n "$sql_file" ]]; then
  exec psql "$url" -f "$sql_file"
elif [[ $# -gt 0 ]]; then
  exec psql "$url" -c "$*"
else
  exec psql "$url"
fi
