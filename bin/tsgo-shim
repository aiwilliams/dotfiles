#!/usr/bin/env bash
# tsgo-shim — serialize tsgo across platform worktrees with flock.
#
# WHY
#   Each tsgo type-check on the platform monorepo uses 13–19 GiB RSS. With
#   multiple worktrees type-checking concurrently, the box runs out of RAM
#   and earlyoom kills tsgo. Editors then complain that their tsgo died.
#   Serializing tsgo invocations across worktrees keeps memory pressure
#   bounded to one tsgo at a time.
#
# HOW
#   pnpm installs the platform-specific binary at a path like
#     <wt>/node_modules/.pnpm/@typescript+native-preview-linux-x64@<ver>/
#       node_modules/@typescript/native-preview-linux-x64/lib/tsgo
#   and (on the same filesystem) hard-links every worktree's copy to one
#   shared inode in pnpm's content-addressable store. We:
#     1. Hard-link the original binary to a sibling `tsgo.real` in the same
#        lib/ directory (preserves the shared inode across worktrees, costs
#        zero extra disk).
#     2. Atomically replace `tsgo` with a small shell shim via rename(2).
#        Rename, not in-place truncate, avoids ETXTBSY if a tsgo is currently
#        running.
#     3. The shim takes a flock and execs `./tsgo.real`. Keeping the real
#        binary in the original lib/ directory matters: tsgo loads its
#        bundled lib.*.d.ts files relative to its own executable path.
#
# MISE NOTE
#   tsgo is invoked indirectly: node_modules/.bin/tsgo is a sh wrapper that
#   runs `node tsgo.js`, and tsgo.js does execFileSync on lib/tsgo. Mise
#   manages which `node` runs the wrapper, but the heavy 13–19 GiB process
#   is the native ELF at lib/tsgo — that's where we intercept. Mise has no
#   bearing on the shim itself, and this driver is plain bash with no Node
#   dependency.
#
# USAGE
#   tsgo-shim              Apply (or refresh) the shim across all worktrees.
#   tsgo-shim --status     Show SHIM/RAW status for each detected lib/tsgo.
#   tsgo-shim --restore    Move tsgo.real back over tsgo (undo).
#
# WHEN TO RUN
#   After every `pnpm install` of the platform repo. The install replaces
#   the shim with a fresh hard link to pnpm's store, so re-shim afterwards.
#   Idempotent and safe to re-run.

set -euo pipefail

PROJECT_GLOB="$HOME/projects/private/opine/platform*"
LOCK_PATH="/run/user/$(id -u)/tsgo-platform.lock"
SHIM_MARKER="# tsgo-shim v2"

bold='\033[1m'; green='\033[32m'; yellow='\033[33m'; reset='\033[0m'

usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# Print every worktree's lib/tsgo path. Empty output if none installed.
# Two layers of globs intentionally expand: $PROJECT_GLOB ends in `platform*`
# and the pnpm package directory is versioned. shellcheck SC2206 flags the
# implicit word-splitting; that's exactly what we want here.
binary_paths() {
  shopt -s nullglob
  # shellcheck disable=SC2206
  local paths=( $PROJECT_GLOB/node_modules/.pnpm/@typescript+native-preview-linux-x64@*/node_modules/@typescript/native-preview-linux-x64/lib/tsgo )
  printf '%s\n' "${paths[@]}"
}

# Cheap check: shim files start with "#!" and contain our marker in the head.
is_shim() {
  head -c 256 "$1" 2>/dev/null | grep -qF "$SHIM_MARKER"
}

# Render the shim content. Always execs ./tsgo.real next to itself, so
# bundled lib.*.d.ts assets resolve via the binary's actual directory.
render_shim() {
  cat <<EOF
#!/bin/sh
$SHIM_MARKER
# Serializes tsgo across platform worktrees via /usr/bin/flock.
# Generated by ~/dotfiles/bin/tsgo-shim. Re-run that after pnpm install.
# To restore by hand: mv "\$(dirname "\$0")/tsgo.real" "\$0".

LOCK="$LOCK_PATH"
REAL="\$(dirname "\$0")/tsgo.real"

# If the lock is currently held, surface it so the caller knows we're queued
# rather than wedged. This is a hint only (the held state can change before
# the real flock below runs); the actual serialization is done by the exec.
if ! /usr/bin/flock -n "\$LOCK" true 2>/dev/null; then
  printf 'tsgo-shim: waiting on %s (another worktree is type-checking)...\n' "\$LOCK" >&2
fi

printf 'tsgo-shim: running %s under flock %s\n' "\$REAL" "\$LOCK" >&2
exec /usr/bin/flock "\$LOCK" "\$REAL" "\$@"
EOF
}

# Replace TARGET (lib/tsgo) with the shim, after preserving the real binary
# at TARGET.real in the same directory. Both ops are crash-safe:
#   - hard-linking tsgo → tsgo.real captures the original inode by a new name.
#   - mv (rename) of the shim over tsgo is atomic; an in-flight tsgo keeps
#     running off the now-unlinked-but-still-open original inode.
shim_one() {
  local target=$1
  local real="${target}.real"
  local dir; dir="$(dirname "$target")"

  # Capture the original inode under tsgo.real if we haven't already.
  if [ ! -e "$real" ]; then
    ln "$target" "$real"
  fi

  # Build the shim in the same directory, then atomically rename into place.
  local tmp; tmp="$(mktemp -p "$dir" .tsgo-shim.XXXXXX)"
  render_shim >"$tmp"
  chmod 0755 "$tmp"
  mv -f "$tmp" "$target"
}

cmd_status() {
  local any=0
  while IFS= read -r p; do
    [ -z "$p" ] && continue
    any=1
    if is_shim "$p"; then
      printf "  ${green}SHIM${reset} %s\n" "$p"
    else
      printf "  ${yellow}RAW${reset}  %s\n" "$p"
    fi
  done < <(binary_paths)
  if [ "$any" = 0 ]; then
    printf "  ${yellow}no tsgo binaries found under %s${reset}\n" "$PROJECT_GLOB"
  fi
}

cmd_apply() {
  local count=0 skipped=0
  while IFS= read -r target; do
    [ -z "$target" ] && continue
    if is_shim "$target"; then
      skipped=$((skipped + 1))
      continue
    fi
    shim_one "$target"
    printf "  ${green}shimmed${reset} %s\n" "$target"
    count=$((count + 1))
  done < <(binary_paths)
  printf "${bold}done:${reset} %d shimmed, %d already-shim\n" "$count" "$skipped"
}

cmd_restore() {
  local count=0
  while IFS= read -r target; do
    [ -z "$target" ] && continue
    local real="${target}.real"
    if [ ! -e "$real" ]; then
      printf "  ${yellow}no tsgo.real next to${reset} %s\n" "$target" >&2
      continue
    fi
    if ! is_shim "$target"; then
      continue
    fi
    mv -f "$real" "$target"
    printf "  ${green}restored${reset} %s\n" "$target"
    count=$((count + 1))
  done < <(binary_paths)
  printf "${bold}done:${reset} %d restored\n" "$count"
}

case "${1:-apply}" in
  apply|'')   cmd_apply   ;;
  --status)   cmd_status  ;;
  --restore)  cmd_restore ;;
  -h|--help)  usage 0     ;;
  *)          usage 1     ;;
esac
