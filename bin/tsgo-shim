#!/usr/bin/env bash
# tsgo-shim — serialize tsgo invocations across one or more project roots.
#
# WHY
#   Each tsgo type-check on a large monorepo can hold 10–20 GiB RSS. With
#   multiple worktrees type-checking concurrently, the box runs out of RAM
#   and earlyoom kills tsgo. Editors then complain that their tsgo died.
#   Serializing tsgo via flock keeps memory pressure to one tsgo at a time.
#
# HOW
#   pnpm installs the platform-specific binary at:
#     <root>/node_modules/.pnpm/@typescript+native-preview-linux-x64@<ver>/
#       node_modules/@typescript/native-preview-linux-x64/lib/tsgo
#   For each lib/tsgo found under each ROOT, this driver:
#     1. Hard-links the original binary to a sibling `tsgo.real` in the same
#        lib/ directory (no extra disk; just a new name for the existing inode).
#     2. Atomically replaces `tsgo` with a small sh shim via rename(2). Rename,
#        not in-place truncate, avoids ETXTBSY if a tsgo is currently running.
#     3. The shim takes a flock and execs `./tsgo.real`. Keeping the real
#        binary in lib/ matters: tsgo loads its bundled lib.*.d.ts files
#        relative to its own executable path.
#
# USAGE
#   tsgo-shim [--lock PATH] [ROOT ...]            apply (or refresh) shims
#   tsgo-shim --status   [ROOT ...]               show SHIM/RAW per lib/tsgo
#   tsgo-shim --restore  [ROOT ...]               undo: mv tsgo.real → tsgo
#
#   ROOT defaults to the current directory if none are given. Multiple ROOTs
#   are walked independently. ROOTs may be any directory containing (directly
#   or several levels deep) a node_modules/.pnpm tree with tsgo installed.
#
#   --lock PATH selects the flock file written into the generated shim.
#   Default: /run/user/$UID/tsgo.lock (one global lock — over-serializes
#   across projects, which is what you want when memory is the constraint).
#   Pass a project-specific path if you'd rather have per-project queues.
#
# WHEN TO RUN
#   After every `pnpm install` of a project that ships tsgo. The install
#   replaces the shim with a fresh hard link to pnpm's store, so re-shim
#   afterwards. Idempotent and safe to re-run.
#
# MISE NOTE
#   tsgo's `node_modules/.bin/tsgo` is a sh wrapper that runs `node tsgo.js`,
#   and tsgo.js does execFileSync on the native lib/tsgo. Mise picks the
#   `node` for the wrapper, but the heavy 10–20 GiB process is the native
#   ELF — that's where we intercept. Mise has no bearing on the shim, and
#   this driver is plain bash with no Node dependency.

set -euo pipefail

DEFAULT_LOCK="/run/user/$(id -u)/tsgo.lock"
SHIM_MARKER="# tsgo-shim v3"

bold='\033[1m'; green='\033[32m'; yellow='\033[33m'; reset='\033[0m'

usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# Print every lib/tsgo path found under any of the given ROOTs.
# Two layers of globs intentionally expand: the ROOT and the versioned
# pnpm package directory.
binary_paths() {
  shopt -s nullglob
  local root
  for root in "$@"; do
    # shellcheck disable=SC2206
    local paths=( "$root"/node_modules/.pnpm/@typescript+native-preview-linux-x64@*/node_modules/@typescript/native-preview-linux-x64/lib/tsgo )
    printf '%s\n' "${paths[@]}"
  done
}

# Cheap check: shim files start with "#!" and contain our marker in the head.
is_shim() {
  head -c 256 "$1" 2>/dev/null | grep -qF "$SHIM_MARKER"
}

# Render the shim content. Always execs ./tsgo.real next to itself, so
# bundled lib.*.d.ts assets resolve via the binary's actual directory.
render_shim() {
  local lock=$1
  cat <<EOF
#!/bin/sh
$SHIM_MARKER
# Serializes tsgo via /usr/bin/flock. Generated by ~/dotfiles/bin/tsgo-shim;
# re-run that after pnpm install. To restore by hand:
#   mv "\$(dirname "\$0")/tsgo.real" "\$0"

LOCK="$lock"
REAL="\$(dirname "\$0")/tsgo.real"

# If the lock is currently held, surface it so the caller knows we're queued
# rather than wedged. This is a hint only (the held state can change before
# the real flock below runs); the actual serialization is done by the exec.
if ! /usr/bin/flock -n "\$LOCK" true 2>/dev/null; then
  printf 'tsgo-shim: waiting on %s (another type-check is running)...\n' "\$LOCK" >&2
fi

printf 'tsgo-shim: running %s under flock %s\n' "\$REAL" "\$LOCK" >&2
exec /usr/bin/flock "\$LOCK" "\$REAL" "\$@"
EOF
}

# Replace TARGET (lib/tsgo) with the shim, after preserving the real binary
# at TARGET.real in the same directory. Both ops are crash-safe:
#   - hard-linking tsgo → tsgo.real captures the original inode by a new name.
#   - mv (rename) of the shim over tsgo is atomic; an in-flight tsgo keeps
#     running off the now-unlinked-but-still-open original inode.
shim_one() {
  local target=$1 lock=$2
  local real="${target}.real"
  local dir; dir="$(dirname "$target")"

  if [ ! -e "$real" ]; then
    ln "$target" "$real"
  fi

  local tmp; tmp="$(mktemp -p "$dir" .tsgo-shim.XXXXXX)"
  render_shim "$lock" >"$tmp"
  chmod 0755 "$tmp"
  mv -f "$tmp" "$target"
}

cmd_status() {
  local any=0
  while IFS= read -r p; do
    [ -z "$p" ] && continue
    any=1
    if is_shim "$p"; then
      printf "  ${green}SHIM${reset} %s\n" "$p"
    else
      printf "  ${yellow}RAW${reset}  %s\n" "$p"
    fi
  done < <(binary_paths "$@")
  if [ "$any" = 0 ]; then
    printf "  ${yellow}no tsgo binaries found under: %s${reset}\n" "$*"
  fi
}

cmd_apply() {
  local lock=$1; shift
  local count=0 skipped=0
  while IFS= read -r target; do
    [ -z "$target" ] && continue
    if is_shim "$target"; then
      skipped=$((skipped + 1))
      continue
    fi
    shim_one "$target" "$lock"
    printf "  ${green}shimmed${reset} %s\n" "$target"
    count=$((count + 1))
  done < <(binary_paths "$@")
  printf "${bold}done:${reset} %d shimmed, %d already-shim\n" "$count" "$skipped"
}

cmd_restore() {
  local count=0
  while IFS= read -r target; do
    [ -z "$target" ] && continue
    local real="${target}.real"
    if [ ! -e "$real" ]; then
      printf "  ${yellow}no tsgo.real next to${reset} %s\n" "$target" >&2
      continue
    fi
    if ! is_shim "$target"; then
      continue
    fi
    mv -f "$real" "$target"
    printf "  ${green}restored${reset} %s\n" "$target"
    count=$((count + 1))
  done < <(binary_paths "$@")
  printf "${bold}done:${reset} %d restored\n" "$count"
}

mode=apply
lock=$DEFAULT_LOCK
roots=()

while [[ $# -gt 0 ]]; do
  case $1 in
    --status)   mode=status; shift ;;
    --restore)  mode=restore; shift ;;
    --lock)     lock=$2; shift 2 ;;
    --lock=*)   lock=${1#--lock=}; shift ;;
    -h|--help)  usage 0 ;;
    --)         shift; roots+=( "$@" ); break ;;
    -*)         usage 1 ;;
    *)          roots+=( "$1" ); shift ;;
  esac
done

if [ ${#roots[@]} -eq 0 ]; then
  roots=( "$PWD" )
fi

case $mode in
  apply)    cmd_apply   "$lock" "${roots[@]}" ;;
  status)   cmd_status         "${roots[@]}" ;;
  restore)  cmd_restore        "${roots[@]}" ;;
esac
