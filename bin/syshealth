#!/usr/bin/env bash
# syshealth — Quick system health overview focused on memory, OOM, tmpfs, and network.
#
# Usage:
#   syshealth                 Full status report
#   syshealth watch           Loop every 60s, only print + bell on problems
#   syshealth watch 30        Loop every 30s
#   syshealth oom             Detailed OOM forensics: oomd policy, heaviest
#                             user scopes, and recent kills decoded
#   syshealth oom-record [s]  Sample per-scope mem/swap to a CSV every [s]s
#                             (default 10); on a fresh oomd/kernel kill, bell
#                             and dump the samples leading up to it
#   syshealth mem [hours]     Replay memsnap history (default 6h): per-unit
#                             current + peak mem/swap with peak timestamps —
#                             answers "what was consuming before that kill?"
#   syshealth mem-sample      Append one sample row per user cgroup to the
#                             memsnap CSV. Run by syshealth-memsnap.timer
#                             every minute; a few ms of cgroupfs reads.
#   (Use `wt ps` for next-server / inngest / database process info)

set -euo pipefail

bold='\033[1m'
red='\033[31m'
green='\033[32m'
yellow='\033[33m'
reset='\033[0m'

section() { printf "\n${bold}── %s${reset}\n" "$1"; }
bell() { printf '\a'; }

# Thresholds
MEM_WARN_PCT=25      # warn when available memory drops below this % of total
SLICE_WARN_PCT=75    # warn when Docker slice usage exceeds this % of its limit
INOTIFY_WARN_PCT=80  # warn when inotify watches/instances exceed this % of limit
TMPFS_WARN_PCT=80    # warn when any tmpfs (esp. /tmp) inode OR byte usage exceeds this %

OS="$(uname -s)"   # Linux | Darwin

# --- Cross-platform helpers ---
#
# This box is Linux; the same script also runs on a macOS laptop. Anything that
# touches /proc, systemd/journalctl, cgroups, inotify, or GNU-only flags is
# Linux-only and is guarded by `$OS`. The shared primitives below paper over the
# Linux/BSD differences so the report logic stays single-sourced.

# Default gateway IP (empty if none). BSD `route` vs iproute2.
default_gateway() {
  if [ "$OS" = Darwin ]; then
    route -n get default 2>/dev/null | awk '/gateway:/{print $2; exit}'
  else
    ip route 2>/dev/null | awk '/^default/ {print $3; exit}'
  fi
}

# One ping with a ~2s deadline. BSD ping spells the timeout -t; GNU ping -W.
ping_host() {
  if [ "$OS" = Darwin ]; then
    ping -c 1 -t 2 "$1" &>/dev/null
  else
    ping -c 1 -W 2 "$1" &>/dev/null
  fi
}

# Path to the tailscale CLI, or empty if not installed. On Linux it's on PATH;
# the macOS app ships its CLI inside the .app bundle instead.
tailscale_bin() {
  if command -v tailscale &>/dev/null; then
    command -v tailscale
  elif [ -x /Applications/Tailscale.app/Contents/MacOS/Tailscale ]; then
    echo /Applications/Tailscale.app/Contents/MacOS/Tailscale
  fi
}

# BackendState ("Running", "Stopped", ...), "?" if the CLI errors, or empty
# if Tailscale isn't installed at all (so callers can stay quiet rather than
# cry wolf on a machine that simply doesn't run it).
tailscale_state() {
  local bin
  bin=$(tailscale_bin)
  [ -z "$bin" ] && return 0
  "$bin" status --self --json 2>/dev/null \
    | python3 -c "import sys,json; print(json.load(sys.stdin).get('BackendState','?'))" 2>/dev/null \
    || echo "?"
}

# Echo "total_kb avail_kb" for system memory.
#
# Linux reads MemAvailable directly. macOS has no single equivalent, so we
# approximate reclaimable memory the way Activity Monitor's "available" does:
# free + inactive + speculative + purgeable + file-backed pages. Good enough to
# drive a percentage warning threshold; not a substitute for memory_pressure.
mem_total_avail() {
  if [ "$OS" = Darwin ]; then
    vm_stat | awk -v ps="$(sysctl -n hw.pagesize)" -v total="$(sysctl -n hw.memsize)" '
      function n(x){ gsub(/[^0-9]/,"",x); return x+0 }
      /Pages free/        { f=n($NF) }
      /Pages inactive/    { i=n($NF) }
      /Pages speculative/ { s=n($NF) }
      /Pages purgeable/   { p=n($NF) }
      /File-backed pages/ { fb=n($NF) }
      END { printf "%d %d\n", total/1024, (f+i+s+p+fb)*ps/1024 }'
  else
    awk '/MemTotal/{t=$2} /MemAvailable/{a=$2} END{print t, a}' /proc/meminfo
  fi
}

# --- Collect checks (used by both modes) ---

collect_alerts() {
  alerts=()

  # Memory
  read -r mem_total mem_avail < <(mem_total_avail)
  mem_pct=$(( mem_avail * 100 / mem_total ))
  if [ "$mem_pct" -lt "$MEM_WARN_PCT" ]; then
    alerts+=("$(printf "${red}Memory: %d%% available (%d MB free of %d MB)${reset}" \
      "$mem_pct" "$(( mem_avail / 1024 ))" "$(( mem_total / 1024 ))")")
  fi

  # inotify watches / instances (both exhaust as a misleading ENOSPC)
  if [ -r /proc/sys/fs/inotify/max_user_watches ]; then
    iw_max=$(cat /proc/sys/fs/inotify/max_user_watches 2>/dev/null || echo 0)
    if [ "${iw_max:-0}" -gt 0 ] 2>/dev/null; then
      iw_used=$(inotify_watches_used)
      iw_pct=$(( ${iw_used:-0} * 100 / iw_max ))
      if [ "$iw_pct" -ge "$INOTIFY_WARN_PCT" ]; then
        alerts+=("$(printf "${red}inotify watches: %d%% of limit (%d / %d) — stale dev daemon in an idle worktree?${reset}" \
          "$iw_pct" "${iw_used:-0}" "$iw_max")")
      fi
    fi
    ii_max=$(cat /proc/sys/fs/inotify/max_user_instances 2>/dev/null || echo 0)
    if [ "${ii_max:-0}" -gt 0 ] 2>/dev/null; then
      ii_used=$(inotify_instances_used)
      ii_pct=$(( ${ii_used:-0} * 100 / ii_max ))
      if [ "$ii_pct" -ge "$INOTIFY_WARN_PCT" ]; then
        alerts+=("$(printf "${red}inotify instances: %d%% of limit (%d / %d)${reset}" \
          "$ii_pct" "${ii_used:-0}" "$ii_max")")
      fi
    fi
  fi

  # tmpfs inode / byte exhaustion — a full tmpfs (especially /tmp under the
  # Node/tsx/pnpm churn) fails every mkdir/open with a misleading ENOSPC while
  # the other dimension, and `df -h`, still look empty. Warn on whichever of
  # inodes/bytes is nearer the wall. (No OS guard needed: tmpfs_usage is empty
  # on macOS, so the loop simply doesn't run.)
  while read -r tgt bpct ipct; do
    [ -z "$tgt" ] && continue
    worst=$bpct; dim=bytes
    if [ "${ipct:-0}" -gt "${worst:-0}" ] 2>/dev/null; then worst=$ipct; dim=inodes; fi
    if [ "${worst:-0}" -ge "$TMPFS_WARN_PCT" ] 2>/dev/null; then
      alerts+=("$(printf "${red}tmpfs %s: %d%% %s used (inodes %d%%, bytes %d%%)${reset}" \
        "$tgt" "$worst" "$dim" "$ipct" "$bpct")")
    fi
  done < <(tmpfs_usage)

  # Docker slice / earlyoom / kernel OOM are systemd + cgroup + journald
  # concepts with no macOS analogue; skip them rather than emit false alarms.
  if [ "$OS" = Linux ]; then
    # Docker slice
    if systemctl is-active docker-containers.slice &>/dev/null; then
      read -r slice_used < /sys/fs/cgroup/docker.slice/docker-containers.slice/memory.current 2>/dev/null || slice_used=0
      read -r slice_max < /sys/fs/cgroup/docker.slice/docker-containers.slice/memory.max 2>/dev/null || slice_max=1
      slice_pct=$(( slice_used * 100 / slice_max ))
      if [ "$slice_pct" -gt "$SLICE_WARN_PCT" ]; then
        alerts+=("$(printf "${red}Docker slice: %d%% of limit (%sG / %sG)${reset}" \
          "$slice_pct" \
          "$(awk "BEGIN{printf \"%.1f\", $slice_used/1073741824}")" \
          "$(awk "BEGIN{printf \"%.0f\", $slice_max/1073741824}")")")
      fi
    else
      alerts+=("$(printf "${red}Docker slice: inactive${reset}")")
    fi

    # earlyoom
    if ! systemctl is-active earlyoom &>/dev/null; then
      alerts+=("$(printf "${red}earlyoom: not running!${reset}")")
    fi

    # earlyoom kills
    kills=$(journalctl -u earlyoom --since "10 minutes ago" --no-pager 2>/dev/null \
      | grep -c "sending SIGTERM to process\|sending SIGKILL to process" || true)
    if [ "$kills" -gt 0 ]; then
      alerts+=("$(printf "${red}earlyoom: %d kill(s) in last 10 min${reset}" "$kills")")
    fi

    # Kernel OOM
    oom_events=$(journalctl --since "10 minutes ago" --no-pager 2>/dev/null | grep -c "Out of memory:" || true)
    if [ "$oom_events" -gt 0 ]; then
      alerts+=("$(printf "${red}Kernel OOM: %d kill(s) in last 10 min${reset}" "$oom_events")")
    fi

    # systemd-oomd kills whole cgroups when its memory+swap pressure thresholds
    # trip — it runs ahead of the kernel OOM killer and ignores earlyoom's
    # per-process avoid/prefer list. A noisy session-cNNN.scope (typically the
    # SSH login + everything spawned from it) is the usual collateral damage.
    oomd_kills=$(journalctl --since "10 minutes ago" --no-pager 2>/dev/null | grep -c "systemd-oomd.*Killed " || true)
    if [ "$oomd_kills" -gt 0 ]; then
      alerts+=("$(printf "${red}systemd-oomd: %d cgroup kill(s) in last 10 min${reset}" "$oomd_kills")")
    fi
  else
    # macOS: jetsam is the OOM mechanism. Surface only sustained pressure.
    if [ "$(sysctl -n kern.memorystatus_vm_pressure_level 2>/dev/null || echo 1)" -ge 2 ] 2>/dev/null; then
      alerts+=("$(printf "${red}Memory pressure: macOS reports elevated (jetsam may kill apps)${reset}")")
    fi
  fi

  # Network
  gw=$(default_gateway)
  if [ -z "$gw" ]; then
    alerts+=("$(printf "${red}Network: no default gateway${reset}")")
  elif ! ping_host "$gw"; then
    alerts+=("$(printf "${red}Network: gateway %s unreachable${reset}" "$gw")")
  fi

  # Tailscale — only alert when it's installed but not Running.
  ts_state=$(tailscale_state)
  if [ -n "$ts_state" ] && [ "$ts_state" != "Running" ]; then
    alerts+=("$(printf "${red}Tailscale: %s${reset}" "$ts_state")")
  fi

  # Network watchdog (systemd timer; Linux only)
  if [ "$OS" = Linux ] && ! systemctl is-active network-watchdog.timer &>/dev/null; then
    alerts+=("$(printf "${yellow}Network watchdog timer: inactive${reset}")")
  fi

  # Airbyte — only alert when the cluster is RUNNING but unhealthy.
  # A stopped cluster is intentional in the turn-it-on-when-you-need-it workflow.
  local airbyte_container="airbyte-abctl-control-plane"
  if [ "$(docker inspect -f '{{.State.Running}}' "$airbyte_container" 2>/dev/null)" = "true" ]; then
    local airbyte_summary
    airbyte_summary=$(airbyte_pod_summary)
    if [ -n "$airbyte_summary" ]; then
      local ready_total max_restart worst
      IFS='|' read -r ready_total max_restart worst <<<"$airbyte_summary"
      if [ "${max_restart:-0}" -gt 10 ]; then
        alerts+=("$(printf "${red}Airbyte: %s crash-looping (%s restarts), pods ready %s${reset}" \
          "$worst" "$max_restart" "$ready_total")")
      fi
    fi
  fi
}

# Returns "ready/total|max_restart|worst_pod_name" or empty string on failure.
# Filters out the bootloader (a one-shot Job that legitimately reports Succeeded).
airbyte_pod_summary() {
  local container="airbyte-abctl-control-plane"
  local pods_json
  pods_json=$(timeout 3 docker exec "$container" \
    kubectl get pods -n airbyte-abctl -o json 2>/dev/null) || return 1
  [ -z "$pods_json" ] && return 1
  printf '%s' "$pods_json" | python3 -c '
import sys, json
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(1)
items = [p for p in d.get("items", []) if "bootloader" not in p["metadata"]["name"]]
if not items:
    sys.exit(1)
ready = 0
max_restart = 0
worst = ""
for p in items:
    cs = p.get("status", {}).get("containerStatuses") or []
    if cs and all(c.get("ready") for c in cs):
        ready += 1
    for c in cs:
        r = c.get("restartCount", 0)
        if r > max_restart:
            max_restart = r
            worst = p["metadata"]["name"]
print(f"{ready}/{len(items)}|{max_restart}|{worst}")
' 2>/dev/null
}

# --- inotify watches ---
#
# Both "too many watches" and "too many instances" surface to userspace as the
# same misleading errno: ENOSPC ("No space left on device"). Watchpack/Next.js,
# the Nx daemon, file-sync, and editors all consume inotify resources, and the
# limits are per-user across every process. A stale dev daemon left running in
# an idle worktree silently holds tens of thousands of watches until something
# new can't start. The kernel exposes no global "in use" counter, so usage must
# be summed from /proc; the scans are timeout-bounded so a huge /proc can't
# stall the health loop.

# find/grep legitimately exit non-zero here (permission-denied entries under
# /proc, grep batches with no match), so under `set -o pipefail` the pipeline
# reports failure even though wc produced a valid count. `|| true` swallows that
# without appending output; the count is then sanitised to digits and defaulted.
digits_or_zero() { local n; n=$(printf '%s' "$1" | tr -dc '0-9'); printf '%s' "${n:-0}"; }

# Echo total inotify watches held across all processes (0 on failure/timeout).
inotify_watches_used() {
  local n
  n=$( { timeout 6 find /proc -maxdepth 3 -path '/proc/[0-9]*/fdinfo/*' -type f \
          -exec grep -h '^inotify ' {} + 2>/dev/null | wc -l; } 2>/dev/null || true )
  digits_or_zero "$n"
}

# Echo total inotify instances (one per watcher fd) across all processes.
inotify_instances_used() {
  local n
  n=$( { timeout 6 find /proc -maxdepth 3 -path '/proc/[0-9]*/fd/*' \
          -lname 'anon_inode:inotify' 2>/dev/null | wc -l; } 2>/dev/null || true )
  digits_or_zero "$n"
}

# Emit "watch_count pid" for the heaviest watch holders, descending. Per-pid
# loop (cheap globs, no arg-list limit); only called from the full report.
inotify_top() {
  local d pid c
  for d in /proc/[0-9]*; do
    [ -d "$d/fdinfo" ] || continue
    pid=${d#/proc/}
    c=$( { grep -h '^inotify ' "$d"/fdinfo/* 2>/dev/null | wc -l; } 2>/dev/null || true )
    c=$(digits_or_zero "$c")
    [ "$c" -gt 0 ] 2>/dev/null && printf '%s %s\n' "$c" "$pid"
  done | sort -rn | head -6
}

# --- tmpfs inode / byte exhaustion ---
#
# A tmpfs enforces BOTH a byte limit and an inode (file-count) cap, and hitting
# EITHER one fails every mkdir/open beneath it with ENOSPC — the same misleading
# errno as inotify exhaustion above, and just as invisible to `df -h`. The
# incident that motivated the /tmp cleanup policy (see install-ubuntu.sh) was
# /tmp at 100% inodes while bytes sat at 11%: a million tiny tsx/node/pnpm cache
# files. So we watch whichever dimension is closer to its wall, per mount.
#
# GNU df --output reports both used% columns in one call; -t tmpfs restricts to
# the in-RAM filesystems (empty on macOS, where the flags are unsupported and
# tmpfs inode caps don't apply, so callers self-skip). Read-only systemd
# credential mounts can't fill from user activity, so they're dropped for legibility.
tmpfs_usage() {
  df --output=target,pcent,ipcent -t tmpfs 2>/dev/null \
    | awk 'NR>1 && $1 !~ "^/run/credentials/" { gsub(/%/,""); print $1, $2+0, $3+0 }'
}

# --- OOM forensics (Linux) ---
#
# systemd-oomd kills whole cgroups from userspace and logs only the cgroup
# path plus aggregate memory/swap % — no per-process dump like the kernel OOM
# killer, and the victim cgroup's memory.events oom_kill counter stays 0 (the
# SIGKILL is userspace, not a cgroup-OOM event). The forensic detail it
# withholds has to be reconstructed from per-scope cgroup accounting, which is
# what these helpers expose. `scope`-wrapped commands (claude sessions, dev
# servers) live as transient *.scope cgroups under this user's app.slice.

# Absolute path to this user's app.slice (empty string if it doesn't exist).
oom_app_slice() {
  local uid; uid=$(id -u)
  printf '/sys/fs/cgroup/user.slice/user-%s.slice/user@%s.service/app.slice' "$uid" "$uid"
}

# Emit one line per app.slice scope, sorted by swap then memory descending:
#   "<swap_bytes> <mem_bytes> <mem_peak_bytes> <swap_peak_bytes> <unit> <cwd>"
# cwd comes from the scope's first process, tracing a scope to the worktree /
# session that owns it. memory.peak / memory.swap.peak are high-water marks
# that survive after a spike subsides — the only record of a transient balloon.
oom_app_scopes() {
  local base; base=$(oom_app_slice)
  [ -d "$base" ] || return 0
  local d unit cur peak sw swpk firstpid cwd
  for d in "$base"/*.scope; do
    [ -d "$d" ] || continue
    unit=$(basename "$d")
    cur=$(cat "$d/memory.current" 2>/dev/null || echo 0)
    peak=$(cat "$d/memory.peak" 2>/dev/null || echo 0)
    sw=$(cat "$d/memory.swap.current" 2>/dev/null || echo 0)
    swpk=$(cat "$d/memory.swap.peak" 2>/dev/null || echo 0)
    firstpid=$(head -n1 "$d/cgroup.procs" 2>/dev/null || true)
    cwd="?"
    [ -n "${firstpid:-}" ] && cwd=$(readlink "/proc/$firstpid/cwd" 2>/dev/null || echo "?")
    printf '%s %s %s %s %s %s\n' "${sw:-0}" "${cur:-0}" "${peak:-0}" "${swpk:-0}" "$unit" "$cwd"
  done | sort -rn
}

# Bytes -> "N.NG" for compact columns.
oom_gb() { awk "BEGIN{printf \"%.1fG\", ${1:-0}/1073741824}"; }

# Shorten an oomd/kernel kill line by stripping the long per-user cgroup
# prefix so the surviving "app.slice/scope-claude-NNN.scope" is legible.
oom_shorten() { sed 's#/user\.slice/user-[0-9]*\.slice/user@[0-9]*\.service/##g'; }

# Emit OOM kill log lines since <since> (any journalctl --since expression):
# systemd-oomd cgroup kills first, then kernel OOM-killer per-process kills.
# Filtered by identifier (-t) and kernel (-k) so it stays fast even when the
# journal is huge — a plain 24h scan can take seconds.
oom_recent_kills() {
  local since="$1"
  { journalctl -t systemd-oomd --since "$since" --no-pager 2>/dev/null | grep "Killed " || true; }
  { journalctl -k --since "$since" --no-pager 2>/dev/null | grep "Out of memory: Killed process" || true; }
}

oom_detail() {
  if [ "$OS" != Linux ]; then
    printf "${yellow}oom detail is Linux-only${reset}\n"
    return 0
  fi

  section "systemd-oomd policy"
  if command -v oomctl >/dev/null 2>&1; then
    oomctl 2>/dev/null \
      | grep -E 'Swap Used Limit:|Default Memory Pressure Limit:|Memory: Used:|Swap: Used:' \
      | sed 's/^[[:space:]]*/  /'
  else
    printf "  ${yellow}oomctl not available${reset}\n"
  fi
  printf "  ${yellow}rule:${reset} oomd only pressure-kills, per-user via user@.service, where\n"
  printf "  ManagedOOMPreference=omit on claude scopes IS honored (same-uid rule).\n"
  printf "  Its swap killer is off — user.slice swap kills ignored omit on\n"
  printf "  user-owned cgroups and took out claude sessions. Swap exhaustion now\n"
  printf "  falls to earlyoom + kernel OOM, which kill per-process (fat child\n"
  printf "  dies, orchestrating session survives).\n"

  section "Heaviest user scopes (swap, then memory)"
  if [ -d "$(oom_app_slice)" ]; then
    printf "  ${bold}%-30s %8s %8s %9s %9s  %s${reset}\n" \
      "scope" "swap" "mem" "mem-peak" "swp-peak" "cwd"
    oom_app_scopes | head -12 | while read -r sw cur peak swpk unit cwd; do
      col="${green}"
      [ "${sw:-0}" -gt 536870912 ] 2>/dev/null && col="${yellow}"
      [ "${sw:-0}" -gt 2147483648 ] 2>/dev/null && col="${red}"
      printf "  ${col}%-30s${reset} %8s %8s %9s %9s  %s\n" \
        "${unit%.scope}" \
        "$(oom_gb "$sw")" "$(oom_gb "$cur")" "$(oom_gb "$peak")" "$(oom_gb "$swpk")" \
        "$cwd"
    done
  else
    printf "  ${yellow}no app.slice (no scope-wrapped sessions running?)${reset}\n"
  fi

  section "Recent OOM kills (last 24h)"
  local found=0 kern oomd
  kern=$(journalctl -k --since "24 hours ago" --no-pager 2>/dev/null \
    | grep "Out of memory: Killed process" | tail -8 || true)
  if [ -n "$kern" ]; then
    found=1
    printf "  ${bold}kernel OOM killer (per-process):${reset}\n"
    printf '%s\n' "$kern" | sed 's/^/    /'
  fi
  oomd=$(journalctl -t systemd-oomd --since "24 hours ago" --no-pager 2>/dev/null \
    | grep "Killed " | tail -8 || true)
  if [ -n "$oomd" ]; then
    found=1
    printf "  ${bold}systemd-oomd (cgroup, no per-process detail):${reset}\n"
    printf '%s\n' "$oomd" | oom_shorten | sed 's/^/    /'
  fi
  [ "$found" -eq 0 ] && printf "  ${green}none in last 24h${reset}\n"

  printf "\n  ${bold}growth history (always-on, 1/min):${reset} syshealth mem [hours]\n"
  printf "  ${bold}live high-frequency capture:${reset} syshealth oom-record [interval_s]\n"
}

# Background sampler: append per-scope mem/swap to a CSV ring buffer so a
# post-mortem growth curve survives a kill (oomd keeps no pre-kill history).
# On a fresh kill it bells and dumps the samples leading up to it.
oom_record() {
  if [ "$OS" != Linux ]; then
    printf "${yellow}oom-record is Linux-only${reset}\n"
    return 0
  fi
  local interval="${1:-10}"
  local dir="${XDG_STATE_HOME:-$HOME/.local/state}/syshealth"
  mkdir -p "$dir"
  local log="$dir/cgroup-mem.csv"
  local maxlines=50000
  printf "Recording app.slice scope mem/swap every %ss to:\n  %s\n" "$interval" "$log"
  printf "On a fresh oomd/kernel kill: bell + dump the run-up samples. Ctrl-C to stop.\n\n"
  [ -s "$log" ] || printf 'epoch,unit,mem_bytes,swap_bytes,mem_peak_bytes,cwd\n' > "$log"

  # Track kills by line content (deduped) rather than a count, so a slow or
  # rotated journal can't cause a miss or a false re-alert. Seed with the last
  # 15 min so pre-existing kills don't fire on startup.
  local seen; seen=$(mktemp)
  oom_recent_kills "15 minutes ago" | sort -u > "$seen" || true

  local ts lines fresh
  while true; do
    ts=$(date +%s)
    oom_app_scopes | while read -r sw cur peak swpk unit cwd; do
      printf '%s,%s,%s,%s,%s,%s\n' "$ts" "$unit" "$cur" "$sw" "$peak" "$cwd" >> "$log"
    done
    lines=$(wc -l < "$log" 2>/dev/null || echo 0)
    if [ "${lines:-0}" -gt "$maxlines" ]; then
      tail -n $((maxlines / 2)) "$log" > "$log.tmp" && mv "$log.tmp" "$log"
    fi

    # Any kill line not already seen is a fresh kill.
    fresh=$(oom_recent_kills "15 minutes ago" | grep -vxF -f "$seen" || true)
    if [ -n "$fresh" ]; then
      bell
      printf "\n${bold}${red}── OOM KILL detected %s${reset}\n" "$(date '+%H:%M:%S')"
      printf '%s\n' "$fresh" | oom_shorten | sed 's/^/  /'
      printf "  ${bold}last samples before the kill:${reset}\n"
      tail -n 24 "$log" | sed 's/^/    /'
      oom_recent_kills "15 minutes ago" | sort -u > "$seen" || true
    fi
    sleep "$interval"
  done
  rm -f "$seen"
}

# --- memsnap: continuous low-cost memory history (Linux) ---
#
# oom-record above is the interactive, high-frequency version you start by
# hand when hunting a live problem. memsnap is its always-on sibling: the
# syshealth-memsnap.timer user unit (installed by install-ubuntu.sh) calls
# `syshealth mem-sample` every minute, appending one row per user cgroup plus
# a _system row. Reading a dozen cgroupfs files costs a few ms, so the history
# is effectively free — and it's the only record of who was growing in the
# hours before an OOM kill, since neither oomd nor the kernel keeps one.

MEMSNAP_LOG="${XDG_STATE_HOME:-$HOME/.local/state}/syshealth/memsnap.csv"
MEMSNAP_MAXLINES=400000     # ~9 days at 1 tick/min with ~30 rows per tick
MEMSNAP_MIN_BYTES=33554432  # skip units under 32M mem AND 32M swap — dozens of
                            # idle run-*/session scopes would drown the history

mem_sample() {
  [ "$OS" = Linux ] || return 0
  mkdir -p "$(dirname "$MEMSNAP_LOG")"
  [ -s "$MEMSNAP_LOG" ] || printf 'epoch,unit,mem_bytes,swap_bytes,info\n' > "$MEMSNAP_LOG"
  local ts; ts=$(date +%s)
  {
    # _system row: used memory / used swap; info carries the memory PSI
    # (some avg60) — the signal oomd's pressure path actually acts on.
    awk -v ts="$ts" '
      /MemTotal/ {t=$2} /MemAvailable/ {a=$2} /SwapTotal/ {st=$2} /SwapFree/ {sf=$2}
      END { printf "%s,_system,%d,%d,", ts, (t-a)*1024, (st-sf)*1024 }' /proc/meminfo
    awk '/^some/ { if (match($0, /avg60=[0-9.]+/)) printf "psi_some_avg60=%s", substr($0, RSTART+6, RLENGTH-6) } END { print "" }' /proc/pressure/memory

    # One row per scope/service under app.slice (claude sessions, clickhouse,
    # scope-wrapped dev servers) and per SSH login session scope. info = cwd
    # of the cgroup's first process, tracing it to its worktree.
    local d unit cur sw firstpid cwd
    for d in "$(oom_app_slice)"/*.scope "$(oom_app_slice)"/*.service \
             "/sys/fs/cgroup/user.slice/user-$(id -u).slice"/session-*.scope; do
      [ -d "$d" ] || continue
      unit=$(basename "$d")
      cur=$(cat "$d/memory.current" 2>/dev/null || echo 0)
      sw=$(cat "$d/memory.swap.current" 2>/dev/null || echo 0)
      [ "${cur:-0}" -lt "$MEMSNAP_MIN_BYTES" ] 2>/dev/null \
        && [ "${sw:-0}" -lt "$MEMSNAP_MIN_BYTES" ] 2>/dev/null && continue
      firstpid=$(head -n1 "$d/cgroup.procs" 2>/dev/null || true)
      cwd=""
      [ -n "${firstpid:-}" ] && cwd=$(readlink "/proc/$firstpid/cwd" 2>/dev/null || true)
      printf '%s,%s,%s,%s,%s\n' "$ts" "$unit" "${cur:-0}" "${sw:-0}" "$cwd"
    done
  } >> "$MEMSNAP_LOG"

  # Self-bound the file: trim to the newest half once over the cap.
  local lines; lines=$(wc -l < "$MEMSNAP_LOG" 2>/dev/null || echo 0)
  if [ "${lines:-0}" -gt "$MEMSNAP_MAXLINES" ]; then
    { head -n1 "$MEMSNAP_LOG"; tail -n $(( MEMSNAP_MAXLINES / 2 )) "$MEMSNAP_LOG"; } > "$MEMSNAP_LOG.tmp" \
      && mv "$MEMSNAP_LOG.tmp" "$MEMSNAP_LOG"
  fi
}

mem_report() {
  if [ "$OS" != Linux ]; then
    printf "${yellow}mem history is Linux-only${reset}\n"
    return 0
  fi
  local hours="${1:-6}"
  if [ ! -s "$MEMSNAP_LOG" ]; then
    printf "${yellow}no samples yet${reset} — expected at %s\n" "$MEMSNAP_LOG"
    printf "sampler timer: %s (enable with: systemctl --user enable --now syshealth-memsnap.timer)\n" \
      "$(systemctl --user is-active syshealth-memsnap.timer 2>/dev/null || echo not-installed)"
    return 0
  fi
  section "Memory history (last ${hours}h, peaks with timestamps)"
  python3 - "$MEMSNAP_LOG" "$hours" <<'PY'
import sys, time

log, hours = sys.argv[1], float(sys.argv[2])
cutoff = time.time() - hours * 3600
units = {}   # unit -> dict(last_ts, last_mem, last_swap, peak_mem, peak_mem_ts, peak_swap, peak_swap_ts, info)
ticks = set()
with open(log) as f:
    next(f, None)  # header
    for line in f:
        parts = line.rstrip("\n").split(",", 4)  # info (a cwd) may contain commas
        if len(parts) < 5:
            continue
        try:
            ts, mem, swap = int(parts[0]), int(parts[2]), int(parts[3])
        except ValueError:
            continue
        if ts < cutoff:
            continue
        ticks.add(ts)
        u = units.setdefault(parts[1], dict(peak_mem=-1, peak_swap=-1))
        u.update(last_ts=ts, last_mem=mem, last_swap=swap)
        if parts[4]:
            u["info"] = parts[4]
        if mem > u["peak_mem"]:
            u.update(peak_mem=mem, peak_mem_ts=ts)
        if swap > u["peak_swap"]:
            u.update(peak_swap=swap, peak_swap_ts=ts)

if not units:
    print(f"  no samples in the last {hours:g}h (timer stopped?)")
    sys.exit(0)

gb = lambda b: f"{b / 2**30:.1f}G"
hm = lambda ts: time.strftime("%H:%M", time.localtime(ts))

span = (max(ticks) - min(ticks)) / 3600 if len(ticks) > 1 else 0
print(f"  {len(ticks)} samples spanning {span:.1f}h")
print(f"  {'unit':<30} {'now':>6} {'peak':>6} {'@':>5}  {'swap':>6} {'swpk':>6} {'@':>5}  info")
sys_row = units.pop("_system", None)
rows = sorted(units.items(), key=lambda kv: (kv[1]["peak_swap"], kv[1]["peak_mem"]), reverse=True)
if sys_row:
    rows.insert(0, ("_system (used)", sys_row))
for name, u in rows[:20]:
    print(f"  {name.removesuffix('.scope'):<30}"
          f" {gb(u['last_mem']):>6} {gb(u['peak_mem']):>6} {hm(u['peak_mem_ts']):>5} "
          f" {gb(u['last_swap']):>6} {gb(u['peak_swap']):>6} {hm(u['peak_swap_ts']):>5} "
          f" {u.get('info', '')}")
dropped = len(rows) - 20
if dropped > 0:
    print(f"  (+{dropped} smaller units not shown)")
PY
  printf "\n  sampler timer: %s   log: %s\n" \
    "$(systemctl --user is-active syshealth-memsnap.timer 2>/dev/null || echo not-installed)" \
    "$MEMSNAP_LOG"
}

# --- Watch mode ---

watch_mode() {
  local interval="${1:-60}"
  printf "Monitoring every %ds (Ctrl-C to stop)...\n" "$interval"
  while true; do
    collect_alerts
    if [ ${#alerts[@]} -gt 0 ]; then
      bell
      printf "\n${bold}${red}── ALERT %s${reset}\n" "$(date '+%H:%M:%S')"
      for a in "${alerts[@]}"; do
        printf "  %b\n" "$a"
      done
    fi
    sleep "$interval"
  done
}

# --- Full report mode ---

full_report() {
  # --- Memory ---
  section "Memory"
  if [ "$OS" = Darwin ]; then
    read -r m_total m_avail < <(mem_total_avail)   # kB
    m_pct=$(( m_avail * 100 / m_total ))
    if   [ "$m_pct" -lt "$MEM_WARN_PCT" ]; then mcol="${red}"
    elif [ "$m_pct" -lt $(( MEM_WARN_PCT + 15 )) ]; then mcol="${yellow}"
    else mcol="${green}"; fi
    printf "  total %.1f GB   avail ${mcol}%.1f GB (%d%%)${reset}   used %.1f GB\n" \
      "$(awk "BEGIN{print $m_total/1048576}")" \
      "$(awk "BEGIN{print $m_avail/1048576}")" \
      "$m_pct" \
      "$(awk "BEGIN{print ($m_total-$m_avail)/1048576}")"
    # Wired + compressor are the non-reclaimable footprint jetsam can't free.
    vm_stat | awk -v ps="$(sysctl -n hw.pagesize)" '
      function n(x){ gsub(/[^0-9]/,"",x); return x+0 }
      /Pages wired down/            { w=n($NF) }
      /Pages occupied by compressor/{ c=n($NF) }
      END { printf "  wired %.1f GB   compressed %.1f GB\n", w*ps/1073741824, c*ps/1073741824 }'
    plevel=$(sysctl -n kern.memorystatus_vm_pressure_level 2>/dev/null || echo 1)
    case "$plevel" in
      1) printf "  pressure: ${green}normal${reset}\n" ;;
      2) printf "  pressure: ${yellow}warning${reset}\n" ;;
      4) printf "  pressure: ${red}critical${reset}\n" ;;
      *) printf "  pressure: ${yellow}unknown (%s)${reset}\n" "$plevel" ;;
    esac
  else
    free -h | awk 'NR<=3'
    printf "  min_free_kbytes: %s MB\n" "$(( $(cat /proc/sys/vm/min_free_kbytes) / 1024 ))"
  fi

  # --- inotify watches ---
  section "inotify watches"
  if [ -r /proc/sys/fs/inotify/max_user_watches ]; then
    iw_max=$(cat /proc/sys/fs/inotify/max_user_watches 2>/dev/null || echo 0)
    ii_max=$(cat /proc/sys/fs/inotify/max_user_instances 2>/dev/null || echo 0)
    iw_used=$(inotify_watches_used)
    ii_used=$(inotify_instances_used)
    show_top=0
    for pair in "watches:${iw_used:-0}:${iw_max:-0}" "instances:${ii_used:-0}:${ii_max:-0}"; do
      label=${pair%%:*}
      rest=${pair#*:}
      used=${rest%%:*}
      max=${rest#*:}
      if [ "${max:-0}" -gt 0 ] 2>/dev/null; then
        pct=$(( used * 100 / max ))
        if [ "$pct" -ge "$INOTIFY_WARN_PCT" ]; then
          col="${red}"
          show_top=1
        elif [ "$pct" -ge $(( INOTIFY_WARN_PCT - 20 )) ]; then
          col="${yellow}"
          show_top=1
        else
          col="${green}"
        fi
        printf "  %-10s ${col}%3d%%${reset}  (%d / %d)\n" "$label" "$pct" "$used" "$max"
      else
        printf "  %-10s ${yellow}unable to read limit${reset}\n" "$label"
      fi
    done
    if [ "$show_top" -eq 1 ]; then
      printf "  ${bold}top watch holders:${reset}\n"
      inotify_top | while read -r cnt pid; do
        cwd=$(readlink "/proc/$pid/cwd" 2>/dev/null || echo "?")
        comm=$(cat "/proc/$pid/comm" 2>/dev/null || echo "?")
        printf "    %7d  ${yellow}%-6s${reset} %-10s %s\n" "$cnt" "$pid" "$comm" "$cwd"
      done
      printf "  idle worktree daemons can be reclaimed with: ${bold}kill <pid>${reset} (they respawn on demand)\n"
    fi
  else
    printf "  ${yellow}not available on this platform${reset}\n"
  fi

  # --- tmpfs (inodes + bytes) ---
  # Same ENOSPC failure class as inotify above: a tmpfs caps both bytes AND
  # inodes, and exhausting either breaks every mkdir/open beneath it while the
  # other dimension — and `df -h` — still look healthy. Inodes first: that's the
  # one that bit /tmp (100% inodes at 11% bytes) and the reason for the hourly
  # cleanup timer, whose liveness we also surface here.
  section "tmpfs"
  if [ "$OS" != Linux ]; then
    printf "  ${yellow}not available on this platform${reset}\n"
  else
    printf "  ${bold}%-16s %7s %7s${reset}\n" "mount" "inodes" "bytes"
    tmpfs_usage | while read -r tgt bpct ipct; do
      [ -z "$tgt" ] && continue
      hi=$bpct; [ "${ipct:-0}" -gt "$hi" ] 2>/dev/null && hi=$ipct
      col="${green}"
      [ "${hi:-0}" -ge $(( TMPFS_WARN_PCT - 20 )) ] 2>/dev/null && col="${yellow}"
      [ "${hi:-0}" -ge "$TMPFS_WARN_PCT" ]        2>/dev/null && col="${red}"
      printf "  ${col}%-16s %6d%% %6d%%${reset}\n" "$tgt" "$ipct" "$bpct"
    done
    if systemctl list-unit-files systemd-tmpfiles-clean.timer &>/dev/null; then
      tstate=$(systemctl is-active systemd-tmpfiles-clean.timer 2>/dev/null)
      [ "$tstate" = active ] && tcol="${green}" || tcol="${red}"
      printf "  cleanup timer: ${tcol}%s${reset} (hourly reaper that keeps /tmp bounded)\n" "$tstate"
    fi
  fi

  # --- Docker slice ---
  # On macOS the Docker daemon runs inside a single Linux VM, so there is no
  # host cgroup slice to read — report the VM's overall footprint instead.
  section "Docker slice"
  if [ "$OS" = Darwin ]; then
    if docker info &>/dev/null; then
      running=$(docker ps -q 2>/dev/null | wc -l | tr -d ' ')
      printf "  Docker Desktop VM: ${green}up${reset}, %s running container(s)\n" "$running"
      printf "  (no host cgroup on macOS; tune memory in Docker Desktop settings)\n"
    else
      printf "  ${yellow}Docker not running${reset}\n"
    fi
  elif systemctl is-active docker-containers.slice &>/dev/null; then
    read -r used < /sys/fs/cgroup/docker.slice/docker-containers.slice/memory.current 2>/dev/null || used=0
    read -r high < /sys/fs/cgroup/docker.slice/docker-containers.slice/memory.high 2>/dev/null || high=0
    read -r max < /sys/fs/cgroup/docker.slice/docker-containers.slice/memory.max 2>/dev/null || max=0
    printf "  used: %sG / high: %sG / max: %sG\n" \
      "$(awk "BEGIN{printf \"%.1f\", $used/1073741824}")" \
      "$(awk "BEGIN{printf \"%.0f\", $high/1073741824}")" \
      "$(awk "BEGIN{printf \"%.0f\", $max/1073741824}")"
  else
    printf "  ${red}inactive${reset}\n"
  fi

  # --- Airbyte (kind cluster) ---
  # The cluster is intended to be turn-it-on-when-you-need-it: nothing on the
  # host autostarts it, and Docker's restart policy only kicks in if dockerd
  # itself restarts. Stopped is a fine resting state — the section's job is to
  # tell you which command turns it back on.
  section "Airbyte (kind cluster)"
  airbyte_container="airbyte-abctl-control-plane"
  if ! docker inspect "$airbyte_container" &>/dev/null; then
    printf "  ${yellow}not installed${reset}\n"
    printf "  install with: ${bold}abctl local install${reset}\n"
  elif [ "$(docker inspect -f '{{.State.Running}}' "$airbyte_container" 2>/dev/null)" != "true" ]; then
    printf "  ${yellow}stopped${reset}\n"
    printf "  start with: ${bold}docker start %s${reset}\n" "$airbyte_container"
  else
    summary=$(airbyte_pod_summary)
    mem=$(docker stats --no-stream --format "{{.MemUsage}}" "$airbyte_container" 2>/dev/null)
    if [ -z "$summary" ]; then
      printf "  ${yellow}running, kubelet not ready yet${reset} (mem %s)\n" "$mem"
    else
      IFS='|' read -r ready_total max_restart worst <<<"$summary"
      ready=${ready_total%/*}
      total=${ready_total#*/}
      if [ "${max_restart:-0}" -gt 10 ]; then
        state_color="${red}"
        state_label="degraded"
      elif [ "$ready" != "$total" ]; then
        state_color="${yellow}"
        state_label="settling"
      else
        state_color="${green}"
        state_label="healthy"
      fi
      printf "  ${state_color}%s${reset} — pods ready %s, mem %s\n" \
        "$state_label" "$ready_total" "$mem"
      if [ "${max_restart:-0}" -gt 10 ]; then
        printf "  ${red}%s: %s restarts (crash-looping)${reset}\n" "$worst" "$max_restart"
        printf "  inspect: ${bold}docker exec %s kubectl -n airbyte-abctl logs %s --previous${reset}\n" \
          "$airbyte_container" "$worst"
      fi
      printf "  stop with: ${bold}docker stop %s${reset}\n" "$airbyte_container"
    fi
  fi

  # --- earlyoom / kernel OOM / OOM protection ---
  # All three are Linux mechanisms (systemd unit, kernel OOM killer, per-pid
  # oom_score_adj). macOS uses jetsam instead, so on Darwin we collapse them
  # into one pressure readout and return early before the Linux-only sections.
  if [ "$OS" = Darwin ]; then
    section "Memory pressure (jetsam)"
    plevel=$(sysctl -n kern.memorystatus_vm_pressure_level 2>/dev/null || echo 1)
    case "$plevel" in
      1) printf "  ${green}normal${reset} — jetsam idle\n" ;;
      2) printf "  ${yellow}warning${reset} — macOS asking apps to free memory\n" ;;
      4) printf "  ${red}critical${reset} — jetsam terminating apps\n" ;;
      *) printf "  ${yellow}unknown (level %s)${reset}\n" "$plevel" ;;
    esac
    swap=$(sysctl -n vm.swapusage 2>/dev/null || echo "")
    [ -n "$swap" ] && printf "  swap: %s\n" "$swap"

    # --- Network ---
    section "Network"
    gw=$(default_gateway)
    if [ -n "$gw" ]; then
      if ping_host "$gw"; then
        printf "  ${green}gateway %s reachable${reset}\n" "$gw"
      else
        printf "  ${red}gateway %s unreachable${reset}\n" "$gw"
      fi
    else
      printf "  ${red}no default gateway${reset}\n"
    fi
    ts_status=$(tailscale_state)
    printf "  tailscale: %s\n" "${ts_status:-not installed}"

    # --- Top memory consumers ---
    section "Top memory consumers"
    # head closes the pipe early; under pipefail that SIGPIPEs sort. Tolerate it.
    { ps -axo %mem=,comm= 2>/dev/null | sort -rn | head -5 \
      | awk '{ m=$1; $1=""; sub(/^ /,""); printf "  %5.1f%%  %s\n", m, $0 }'; } || true
    return 0
  fi

  section "earlyoom"
  if systemctl is-active earlyoom &>/dev/null; then
    # Show current memory reading with age
    last_ts=$(journalctl -u earlyoom --no-pager -n 1 -o short-unix 2>/dev/null | awk '{print int($1)}')
    last_msg=$(journalctl -u earlyoom --no-pager -n 1 -o cat 2>/dev/null)
    if [ -n "$last_ts" ] && [ "$last_ts" -gt 0 ] 2>/dev/null; then
      age=$(( $(date +%s) - last_ts ))
      if [ "$age" -lt 60 ]; then
        age_str="${age}s ago"
      elif [ "$age" -lt 3600 ]; then
        age_str="$(( age / 60 ))m ago"
      else
        age_str="$(( age / 3600 ))h$(( (age % 3600) / 60 ))m ago"
      fi
      printf "  %s\n" "$last_msg"
      printf "  ${yellow}(last reading: %s)${reset}\n" "$age_str"
    fi
    # Show any kills in the last 24h
    kills=$(journalctl -u earlyoom --since "24 hours ago" --no-pager 2>/dev/null | grep -c "sending SIGTERM to process\|sending SIGKILL to process" || true)
    if [ "$kills" -gt 0 ]; then
      printf "  ${red}%d kill(s) in last 24h:${reset}\n" "$kills"
      journalctl -u earlyoom --since "24 hours ago" --no-pager 2>/dev/null | grep "sending SIGTERM to process\|sending SIGKILL to process" | tail -5 | sed 's/^/    /'
    else
      printf "  ${green}no kills in last 24h${reset}\n"
    fi
  else
    printf "  ${red}inactive!${reset}\n"
  fi

  # --- OOM killer (kernel) ---
  section "Kernel OOM kills (last 24h)"
  oom_events=$(journalctl --since "24 hours ago" --no-pager 2>/dev/null | grep -c "Out of memory:" || true)
  if [ "$oom_events" -gt 0 ]; then
    printf "  ${red}%d kernel OOM kill(s)${reset}\n" "$oom_events"
    journalctl --since "24 hours ago" --no-pager 2>/dev/null | grep "Out of memory:" | tail -5 | sed 's/^/    /'
  else
    printf "  ${green}none${reset}\n"
  fi

  # --- systemd-oomd ---
  # Reports kills made by systemd-oomd. Unlike earlyoom, which targets
  # individual processes and respects an avoid/prefer regex, systemd-oomd
  # selects whole cgroups by swap usage or PSI and kills them outright. When
  # the heaviest cgroup happens to be the SSH login session scope, the
  # connection itself is what dies — and the protections on tailscaled / sshd
  # do not apply, because the kill is at the cgroup, not the process.
  if systemctl list-unit-files systemd-oomd.service 2>/dev/null | grep -q systemd-oomd.service; then
    section "systemd-oomd kills (last 24h)"
    if systemctl is-active systemd-oomd &>/dev/null; then
      oomd_kills=$(journalctl --since "24 hours ago" --no-pager 2>/dev/null | grep -c "systemd-oomd.*Killed " || true)
      if [ "$oomd_kills" -gt 0 ]; then
        printf "  ${red}%d systemd-oomd kill(s)${reset}\n" "$oomd_kills"
        journalctl --since "24 hours ago" --no-pager 2>/dev/null | grep "systemd-oomd.*Killed " | tail -5 | sed 's/^/    /'
        printf "  isolate dev servers in their own scope (${bold}scope <cmd>${reset}) so a kill spares the SSH session\n"
        printf "  forensics — policy, heaviest scopes, decoded kills: ${bold}syshealth oom${reset}\n"
        printf "  who was growing before the kill: ${bold}syshealth mem 24${reset}\n"
      else
        printf "  ${green}none${reset}\n"
      fi
    else
      printf "  ${yellow}inactive${reset}\n"
    fi
  fi

  # --- OOM protection ---
  section "OOM protection"
  for svc in tailscaled sshd; do
    pid=$(pgrep -x "$svc" -o 2>/dev/null || true)
    if [ -n "$pid" ]; then
      score=$(cat "/proc/$pid/oom_score_adj" 2>/dev/null || echo "?")
      printf "  %s (pid %s): oom_score_adj=%s\n" "$svc" "$pid" "$score"
    else
      printf "  %s: ${yellow}not running${reset}\n" "$svc"
    fi
  done

  # --- Network ---
  section "Network"
  gw=$(ip route | awk '/^default/ {print $3; exit}')
  if [ -n "$gw" ]; then
    if ping -c 1 -W 2 "$gw" &>/dev/null; then
      printf "  ${green}gateway %s reachable${reset}\n" "$gw"
    else
      printf "  ${red}gateway %s unreachable${reset}\n" "$gw"
    fi
  else
    printf "  ${red}no default gateway${reset}\n"
  fi
  ts_status=$(tailscale_state)
  printf "  tailscale: %s\n" "${ts_status:-not installed}"
  printf "  watchdog timer: %s\n" "$(systemctl is-active network-watchdog.timer 2>/dev/null)"

  # --- Top memory consumers ---
  section "Top memory consumers"
  ps aux --sort=-%mem --no-headers | head -5 | awk '{printf "  %5.1f%%  %s\n", $4, $11}'
}

# --- Main ---

case "${1:-}" in
  watch)      watch_mode "${2:-60}" ;;
  oom)        oom_detail ;;
  oom-record) oom_record "${2:-10}" ;;
  mem)        mem_report "${2:-6}" ;;
  mem-sample) mem_sample ;;
  *)          full_report ;;
esac
